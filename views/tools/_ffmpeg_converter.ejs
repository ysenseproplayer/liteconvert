<%
  // Detect format meta from tool_key
  const ffmpegMeta = {
    'mp4-to-mp3': { inputExt: 'mp4', inputLabel: 'MP4 Video', inputAccept: '.mp4,video/mp4' },
    'm4a-to-mp3': { inputExt: 'm4a', inputLabel: 'M4A Audio', inputAccept: '.m4a,audio/m4a,audio/mp4' },
    'opus-to-mp3': { inputExt: 'opus', inputLabel: 'OPUS Audio', inputAccept: '.opus,audio/ogg,audio/opus' },
    'webm-to-mp3': { inputExt: 'webm', inputLabel: 'WebM File', inputAccept: '.webm,video/webm,audio/webm' },
    'aac-to-mp3': { inputExt: 'aac', inputLabel: 'AAC Audio', inputAccept: '.aac,audio/aac' },
    'wma-to-mp3': { inputExt: 'wma', inputLabel: 'WMA Audio', inputAccept: '.wma,audio/x-ms-wma' },
    'aiff-to-mp3': { inputExt: 'aiff,aif', inputLabel: 'AIFF Audio', inputAccept: '.aiff,.aif,audio/aiff,audio/x-aiff' },
    'ogg-to-wav': { inputExt: 'ogg', inputLabel: 'OGG File', inputAccept: '.ogg,audio/ogg', outputExt: 'wav', outputLabel: 'WAV' },
    'avi-to-mp3': { inputExt: 'avi', inputLabel: 'AVI Video', inputAccept: '.avi,video/avi,video/x-msvideo' },
    'mkv-to-mp3': { inputExt: 'mkv', inputLabel: 'MKV Video', inputAccept: '.mkv,video/x-matroska' },
    'flac-mp3': { inputExt: 'flac', inputLabel: 'FLAC Audio', inputAccept: '.flac,audio/flac' },
    'ogg-mp3': { inputExt: 'ogg', inputLabel: 'OGG Audio', inputAccept: '.ogg,audio/ogg' },
    'video-extractor': { inputExt: 'mp4,mkv,avi,webm,mov', inputLabel: 'Video File', inputAccept: 'video/*' },
    '3gp-to-mp3': { inputExt: '3gp', inputLabel: '3GP Video', inputAccept: '.3gp,video/3gpp' },
    'amr-mp3': { inputExt: 'amr', inputLabel: 'AMR Audio', inputAccept: '.amr,audio/amr' },
    'alac-to-mp3': { inputExt: 'm4a', inputLabel: 'ALAC/M4A Audio', inputAccept: '.m4a,audio/mp4' },
    'mov-mp3': { inputExt: 'mov', inputLabel: 'MOV Video', inputAccept: '.mov,video/quicktime' },
    'mp3-ogg': { inputExt: 'mp3', inputLabel: 'MP3 Audio', inputAccept: '.mp3,audio/mpeg', outputExt: 'ogg', outputLabel: 'OGG' },
    'mp3-wav': { inputExt: 'mp3', inputLabel: 'MP3 Audio', inputAccept: '.mp3,audio/mpeg', outputExt: 'wav', outputLabel: 'WAV' },
    'cnv-mp3': { inputExt: 'flac,ogg,m4a,aac,wav', inputLabel: 'Any Audio File', inputAccept: 'audio/*' },
    'mp3-to-m4r': { inputExt: 'mp3', inputLabel: 'MP3 Audio', inputAccept: '.mp3,audio/mpeg', outputExt: 'm4r', outputLabel: 'M4R Ringtone' },
    'bitrate-changer': { inputExt: 'mp3', inputLabel: 'MP3 Audio', inputAccept: '.mp3,audio/mpeg', outputExt: 'mp3', outputLabel: 'MP3' },
    'mp3-compressor': { inputExt: 'mp3', inputLabel: 'MP3 Audio', inputAccept: '.mp3,audio/mpeg', outputExt: 'mp3', outputLabel: 'Compressed MP3' },
    'mp3-wave': { inputExt: 'mp3', inputLabel: 'MP3 Audio', inputAccept: '.mp3,audio/mpeg', outputExt: 'wav', outputLabel: 'WAV' },
  };
  const meta = ffmpegMeta[tool.tool_key] || { inputExt: 'audio', inputLabel: 'Audio File', inputAccept: 'audio/*,video/*' };
  const outputExt = meta.outputExt || 'mp3';
  const outputLabel = meta.outputLabel || 'MP3';
%>

<div class="audio-workbench" data-tool-key="<%= tool.tool_key %>" data-tool-category="<%= tool.category %>"
     data-output-ext="<%= outputExt %>" data-output-label="<%= outputLabel %>" data-input-ext="<%= meta.inputExt %>">
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
    </div>
    <div class="tool-hero-text"><p class="tool-hero-desc"><%= tool.intro_paragraph || tool.page_description %></p></div>
    <div class="tool-hero-badges">
      <span class="hero-badge">100% Free</span>
      <span class="hero-badge">Privacy Safe</span>
      <span class="hero-badge">Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 640px; margin: 0 auto;">

    <!-- Upload Zone -->
    <div id="ffcv-upload-card" class="tool-panel" style="margin-bottom: 1.5rem;">
      <div class="panel-label">Upload <%= meta.inputLabel %></div>
      <div id="ffcv-drop-zone" class="cv-dropzone" style="margin-top: 0.75rem;">
        <input type="file" id="ffcv-file-input" style="display:none;" accept="<%= meta.inputAccept %>">
        <div class="cv-dropzone-icon">
          <svg width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
        </div>
        <div class="cv-dropzone-text">
          <strong>Drop your <%= meta.inputLabel %> here or click to browse</strong>
          <span>File stays on your device — 100% private</span>
        </div>
        <div class="cv-dropzone-btn">Choose File</div>
      </div>
    </div>

    <!-- File Ready Panel -->
    <div id="ffcv-file-panel" class="tool-panel hidden" style="margin-bottom: 1.5rem;">
      <div class="panel-label">Ready to Convert</div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 0.75rem; background: rgba(0,0,0,0.15); border: 1px solid var(--card-border); padding: 0.75rem 1rem; border-radius: 8px;">
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--accent-primary); flex-shrink: 0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
          <div>
            <div id="ffcv-file-name" style="font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">file.mp4</div>
            <div id="ffcv-file-size" style="font-size: 0.78rem; color: var(--text-muted);">— MB</div>
          </div>
        </div>
        <div style="display: flex; align-items: center; gap: 0.75rem;">
          <span style="font-size: 0.8rem; color: var(--text-muted);">→</span>
          <span style="font-size: 0.9rem; font-weight: 700; color: var(--accent-primary); background: rgba(0,242,254,0.08); border: 1px solid rgba(0,242,254,0.2); padding: 0.2rem 0.65rem; border-radius: 6px;"><%= outputLabel %></span>
          <button id="ffcv-btn-remove" style="background: transparent; border: none; color: var(--danger); cursor: pointer; font-size: 1.2rem; font-weight: bold;">&times;</button>
        </div>
      </div>
      <button id="ffcv-btn-convert" class="btn-main-action" style="width: 100%; margin-top: 1.25rem;">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M4 4l4 4" /></svg>
        Convert to <%= outputLabel %>
      </button>
    </div>

    <!-- Processing Card -->
    <div id="ffcv-processing-card" class="tool-panel hidden" style="text-align: center; margin-bottom: 1.5rem; padding: 2rem;">
      <div id="ffcv-processing-status" style="font-size: 1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 1rem;">Decoding audio stream...</div>
      <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
        <div id="ffcv-progress-bar" style="width: 0%; height: 100%; background: var(--accent-gradient); border-radius: 3px; transition: width 0.3s;"></div>
      </div>
      <div id="ffcv-processing-detail" style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.75rem;">Processing audio...</div>
    </div>

    <!-- Download Card -->
    <div id="ffcv-download-card" class="tool-panel hidden" style="text-align: center; padding: 2rem; border: 1px solid rgba(16,185,129,0.2); background: rgba(16,185,129,0.02);">
      <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--success); margin: 0 auto 1rem; display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <h3 style="font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Conversion Complete!</h3>
      <p id="ffcv-output-info" style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Output: <%= outputLabel %></p>
      <a id="ffcv-download-link" href="" download class="btn btn-success" style="background: var(--success); color: white; padding: 0.75rem 2rem; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600; margin-bottom: 1rem;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download <%= outputLabel %>
      </a>
      <br>
      <button id="ffcv-btn-convert-another" class="ctrl-btn-mini" style="margin-top: 0.5rem;">Convert Another File</button>
    </div>

  </div>
</div>


