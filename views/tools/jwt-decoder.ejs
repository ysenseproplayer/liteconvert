<div class="grid-layout">
  <div class="card pane-card">
    <div class="pane-header"><span>Enter Encoded JWT Token</span></div>
    <textarea id="jwt-input" class="pane-textarea mono" placeholder="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..." style="min-height:350px;"></textarea>
  </div>
  <div class="card" style="display:flex; flex-direction:column; gap:1.25rem;">
    <h3>Token Payload</h3>
    <div class="settings-group"><label>Header (Algorithms & Types)</label><textarea id="jwt-header" class="pane-textarea mono" readonly style="min-height:100px; background-color:rgba(15,22,34,0.4);"></textarea></div>
    <div class="settings-group"><label>Payload (Claims & Variables)</label><textarea id="jwt-payload" class="pane-textarea mono" readonly style="min-height:160px; background-color:rgba(15,22,34,0.4);"></textarea></div>
  </div>
</div>
