<div class="split-pane" style="margin-bottom:1.5rem;">
  <div class="card pane-card" style="min-height:250px;"><div class="pane-header"><span>Original Text</span></div><textarea id="diff-text-1" class="pane-textarea" placeholder="Paste original copy here..." style="min-height:160px;"></textarea></div>
  <div class="card pane-card" style="min-height:250px;"><div class="pane-header"><span>Modified Text</span></div><textarea id="diff-text-2" class="pane-textarea" placeholder="Paste modified copy here..." style="min-height:160px;"></textarea></div>
</div>
<div class="card"><div class="pane-header"><span>Visual Diff Results</span></div><div id="diff-checker-output" style="padding:1rem; border:1px solid var(--card-border); border-radius:var(--radius-md); background:var(--bg-secondary); min-height:100px; font-family:var(--font-mono); font-size:0.85rem; line-height:1.6; white-space:pre-wrap;">Diff highlights will display here once you type...</div></div>
