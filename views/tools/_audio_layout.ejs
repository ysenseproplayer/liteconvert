<% const isGenerator = ['blank-mp3', 'white-noise', 'metronome', 'text-to-mp3'].includes(tool.tool_key); %>

<div class="audio-workbench" data-tool-key="<%= tool.tool_key %>" data-tool-category="<%= tool.category %>">

  <!-- TOOL HERO HEADER -->
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
      </svg>
    </div>
    <div class="tool-hero-text">
      <p class="tool-hero-desc"><%= tool.intro_paragraph || tool.page_description %></p>
    </div>
    <div class="tool-hero-badges">
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg> 100% Free</span>
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg> Privacy Safe</span>
      <span class="hero-badge"><svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg> Browser-Side</span>
    </div>
  </div>

  <% if (isGenerator) { %>
    <!-- ============================
         GENERATOR LAYOUT
         ============================ -->
    <div class="tool-main-grid">
      
      <!-- LEFT: PLAYER / VISUALIZER -->
      <div class="tool-panel">
        <div class="panel-label">Preview</div>
        <div class="panel-player" id="player-section">
          <div class="player-topbar">
            <span class="player-filename" id="file-name">Generated Audio</span>
          </div>
          
          <div class="modern-player-bar">
            <!-- Left: Play/Pause action button -->
            <button class="player-play-btn" id="btn-play-pause" title="Play / Pause">
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" id="play-icon"><path d="M8 5v14l11-7z" /></svg>
              <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24" id="pause-icon" class="hidden"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" /></svg>
            </button>

            <!-- Middle: Waveform Visualizer -->
            <div class="player-canvas-wrap">
              <canvas id="visualizer-canvas" height="56" style="width:100%; height:56px; display:block;"></canvas>
              <div id="waveform-progress" style="position:absolute;top:0;left:0;width:0%;height:100%;background:rgba(0,242,254,0.07);pointer-events:none;"></div>
            </div>

            <!-- Right: Time Indicators -->
            <div class="player-time-info">
              <span id="player-current-time">00:00</span>
              <span class="time-separator">/</span>
              <span id="file-duration">00:05</span>
            </div>
          </div>

          <!-- Secondary Player controls: Stop and Loop -->
          <div class="player-secondary-controls">
            <button class="ctrl-btn-mini" id="btn-stop" title="Stop">
              <svg width="11" height="11" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h12v12H6z" /></svg>
              <span>Stop</span>
            </button>
            <button class="ctrl-btn-mini" id="btn-loop" title="Toggle Loop">
              <svg width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M9 11l3 3 6-6" /></svg>
              <span>Loop</span>
            </button>
          </div>
        </div>
      </div>

      <!-- RIGHT: GENERATOR CONTROLS -->
      <div class="tool-panel">
        <div class="panel-label">Settings</div>
        <div class="panel-settings" id="settings-card">
          <div id="dynamic-controls-container" style="display:flex; flex-direction:column; gap:1rem;">
            <% if (tool.tool_key === 'text-to-mp3') { %>
              <div class="ctrl-group">
                <label class="ctrl-label">Text to Convert</label>
                <textarea id="tts-text" class="pane-textarea" style="min-height:100px; font-size:0.9rem;" placeholder="Type text to speak...">Tomp3 voice reader synthesized successfully.</textarea>
              </div>
            <% } %>

            <button class="btn-outline-accent" id="btn-config-modal-trigger">
              <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
              Configure Parameters
            </button>

            <button class="btn-main-action" id="btn-process-audio">
              <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Generate & Convert
            </button>
          </div>
        </div>

        <!-- Progress -->
        <div class="panel-progress hidden" id="processing-card">
          <div class="progress-status" id="processing-status">Synthesizing audio...</div>
          <div class="progress-track">
            <div class="progress-bar" id="processing-progress-bar" style="width:10%;"></div>
          </div>
        </div>

        <!-- Download -->
        <div class="panel-download hidden" id="download-card">
          <div class="download-icon">
            <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          </div>
          <div class="download-info">
            <strong>Ready to Download!</strong>
            <span id="download-file-size">Calculating...</span>
          </div>
          <a href="" id="download-link" download class="btn-download">
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
            Download File
          </a>
        </div>
      </div>
    </div>

  <% } else { %>
    <!-- ============================
         CONVERTER / DSP LAYOUT
         ============================ -->
    <div class="converter-ui">

      <!-- STEP 1: UPLOAD -->
      <div class="cv-step" id="step-1-section">
        <div class="cv-step-num">
          <span>1</span>
        </div>
        <div class="cv-step-body">
          <h3 class="cv-step-title">Open Your Audio File</h3>

          <!-- Drop Zone -->
          <div class="cv-dropzone" id="drop-zone">
            <input type="file" id="audio-file-input" style="display:none;" accept="audio/*,video/*" <%= tool.tool_key === 'audio-joiner' ? 'multiple' : '' %>>
            <div class="cv-dropzone-icon">
              <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
            </div>
            <div class="cv-dropzone-text">
              <strong id="step1-upload-label"><%= tool.tool_key === 'audio-joiner' ? 'Drop files here or click to queue them' : 'Drop file here or click to browse' %></strong>
              <span>Supports MP3, WAV, OGG, FLAC, M4A, WEBM, MP4 and more</span>
            </div>
            <div class="cv-dropzone-btn">Choose File<%= tool.tool_key === 'audio-joiner' ? '(s)' : '' %></div>
          </div>

          <% if (tool.tool_key === 'audio-joiner') { %>
            <div id="joiner-queue-container" class="hidden" style="margin-top:1.5rem; display:flex; flex-direction:column; gap:0.75rem;">
              <div class="ctrl-label" style="display:flex; justify-content:space-between; align-items:center;">
                <span>Merge Queue</span>
                <span id="queue-count" style="font-family:var(--font-mono); color:var(--accent-primary);">0 tracks</span>
              </div>
              <div id="joiner-queue" style="display:flex; flex-direction:column; gap:0.5rem; background:rgba(0,0,0,0.15); border: 1px solid var(--card-border); border-radius:8px; padding:0.75rem;"></div>
            </div>
          <% } %>

          <!-- Cloud links -->
          <div class="cv-cloud-links">
            <a href="#" onclick="alert('Google Drive coming soon!')" class="cv-cloud-link">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M19.345 9.006h-5.267l-2.61-4.515c-.134-.233-.38-.376-.649-.376H5.556c-.27 0-.515.143-.65.376L1.082 11.23a.755.755 0 000 .75l3.824 6.741c.134.232.38.375.65.375h5.266c.27 0 .515-.143.65-.375l2.61-4.516h5.267c.414 0 .75-.336.75-.75v-3.75a.75.75 0 00-.75-.75z"/></svg>
              Google Drive
            </a>
            <a href="#" onclick="alert('Dropbox coming soon!')" class="cv-cloud-link">
              <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L2 8.3L7 11.5L12 8.3L17 11.5L22 8.3L12 2Z M2 14.6L7 11.5L12 14.6L17 11.5L22 14.6L12 20.8L2 14.6Z"/></svg>
              Dropbox
            </a>
            <a href="#" onclick="const u=prompt('Paste file URL:'); if(u) alert('Fetching: '+u);" class="cv-cloud-link">
              <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
              From URL
            </a>
          </div>

          <!-- Waveform preview (shown after upload) -->
          <div class="cv-player hidden" id="player-section">
            <div class="cv-player-info">
              <div class="cv-player-icon">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
              </div>
              <span id="file-name" class="cv-player-name">track.wav</span>
            </div>
            
            <div class="modern-player-bar">
              <!-- Left: Play/Pause button -->
              <button class="player-play-btn" id="btn-play-pause" title="Play / Pause">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" id="play-icon"><path d="M8 5v14l11-7z" /></svg>
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" id="pause-icon" class="hidden"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" /></svg>
              </button>

              <!-- Middle: Waveform Canvas -->
              <div class="player-canvas-wrap">
                <canvas id="visualizer-canvas" height="56" style="width:100%; height:56px; display:block;"></canvas>
                <div id="waveform-progress" style="position:absolute;top:0;left:0;width:0%;height:100%;background:rgba(0,242,254,0.07);pointer-events:none;"></div>
              </div>

              <!-- Right: Time Indicators -->
              <div class="player-time-info">
                <span id="player-current-time">00:00</span>
                <span class="time-separator">/</span>
                <span id="file-duration">00:00</span>
              </div>
            </div>

            <!-- Secondary Stop Control -->
            <div class="player-secondary-controls">
              <button class="ctrl-btn-mini" id="btn-stop" title="Stop">
                <svg width="10" height="10" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h12v12H6z" /></svg>
                <span>Stop</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- STEP 2: SETTINGS -->
      <div class="cv-step disabled" id="step-2-section">
        <div class="cv-step-num">
          <span>2</span>
        </div>
        <div class="cv-step-body">
          <h3 class="cv-step-title">Choose Format & Quality</h3>

          <!-- Format pills -->
          <div class="cv-format-row">
            <span class="cv-format-label">Output Format</span>
            <div class="cv-format-pills" id="format-group">
              <button class="cv-pill active" data-format="mp3">MP3</button>
              <button class="cv-pill" data-format="wav">WAV</button>
              <button class="cv-pill" data-format="m4a">M4A</button>
              <button class="cv-pill" data-format="ogg">OGG</button>
              <button class="cv-pill" data-format="flac">FLAC</button>
              <button class="cv-pill" data-format="aac">AAC</button>
            </div>
          </div>

          <!-- Quality -->
          <div class="cv-quality-row">
            <div class="cv-quality-header">
              <span>Quality</span>
              <span class="cv-quality-val" id="val-audio-bitrate">192 kbps</span>
            </div>
            <input type="range" id="audio-bitrate-slider" class="styled-slider" min="0" max="3" value="2" style="width:100%; margin: 0.5rem 0;">
            <div class="cv-quality-labels">
              <span>64k</span><span>128k</span><span>192k</span><span>320k</span>
            </div>
          </div>

          <!-- Advanced accordion -->
          <div class="cv-accordion" id="advanced-settings-accordion">
            <button class="cv-accordion-trigger" id="accordion-toggle-btn">
              <span>
                <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
                Advanced Options
              </span>
              <svg class="accordion-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            <div class="accordion-content">
              <div class="accordion-body">
                <div class="settings-group">
                  <label class="ctrl-label">Channels</label>
                  <div class="radio-group-btn">
                    <input type="radio" name="audio-channels" id="channels-original" value="original" checked>
                    <label class="radio-btn-label" for="channels-original">Original</label>
                    <input type="radio" name="audio-channels" id="channels-mono" value="mono">
                    <label class="radio-btn-label" for="channels-mono">Mono</label>
                    <input type="radio" name="audio-channels" id="channels-stereo" value="stereo">
                    <label class="radio-btn-label" for="channels-stereo">Stereo</label>
                  </div>
                </div>
                <div class="settings-group">
                  <label class="ctrl-label">Sample Rate</label>
                  <div class="radio-group-btn">
                    <input type="radio" name="sample-rate" id="srate-original" value="original" checked>
                    <label class="radio-btn-label" for="srate-original">Original</label>
                    <input type="radio" name="sample-rate" id="srate-44" value="44100">
                    <label class="radio-btn-label" for="srate-44">44.1 kHz</label>
                    <input type="radio" name="sample-rate" id="srate-48" value="48000">
                    <label class="radio-btn-label" for="srate-48">48 kHz</label>
                  </div>
                </div>

                <!-- DSP Modifiers -->
                <% if (tool.tool_key === 'volume-booster') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Volume Level</span><span id="val-volume-gain" style="font-family:var(--font-mono);">200%</span></label>
                    <input type="range" id="volume-gain" class="styled-slider" min="100" max="500" step="10" value="200" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'speed-changer') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Speed Factor</span><span id="val-speed-factor" style="font-family:var(--font-mono);">1.0x</span></label>
                    <input type="range" id="speed-factor" class="styled-slider" min="0.5" max="2.0" step="0.05" value="1.0" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'pitch-shifter') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Semitones Pitch</span><span id="val-pitch-semitones" style="font-family:var(--font-mono);">0</span></label>
                    <input type="range" id="pitch-semitones" class="styled-slider" min="-12" max="12" step="1" value="0" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'bass-booster') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Bass Gain (dB)</span><span id="val-bass-gain" style="font-family:var(--font-mono);">+6 dB</span></label>
                    <input type="range" id="bass-gain" class="styled-slider" min="0" max="24" step="1" value="6" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'slowed-reverb') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Speed Slow Down</span><span id="val-slow-factor" style="font-family:var(--font-mono);">0.80x</span></label>
                    <input type="range" id="slow-factor" class="styled-slider" min="0.5" max="0.95" step="0.01" value="0.80" style="width:100%;">
                  </div>
                  <div class="ctrl-group" style="margin-top:0.75rem;">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Reverb Level</span><span id="val-reverb-mix" style="font-family:var(--font-mono);">40%</span></label>
                    <input type="range" id="reverb-mix" class="styled-slider" min="10" max="100" step="5" value="40" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'audio-fade') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Fade In (s)</span><span id="val-fade-in" style="font-family:var(--font-mono);">2.0s</span></label>
                    <input type="range" id="fade-in" class="styled-slider" min="0" max="10" step="0.5" value="2.0" style="width:100%;">
                  </div>
                  <div class="ctrl-group" style="margin-top:0.75rem;">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Fade Out (s)</span><span id="val-fade-out" style="font-family:var(--font-mono);">2.0s</span></label>
                    <input type="range" id="fade-out" class="styled-slider" min="0" max="10" step="0.5" value="2.0" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'voice-changer') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label">Voice Preset</label>
                    <select id="voice-preset" class="styled-select">
                      <option value="chipmunk">Chipmunk (High Pitch)</option>
                      <option value="monster">Monster (Deep)</option>
                      <option value="robot">Robot Synthesizer</option>
                      <option value="helium">Helium Gas</option>
                      <option value="echo">Cave Echo</option>
                    </select>
                  </div>
                <% } else if (tool.tool_key === 'audio-splitter') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label">Split Method</label>
                    <select id="splitter-method" class="styled-select">
                      <option value="duration">By Equal Duration</option>
                      <option value="parts">By Equal Parts</option>
                    </select>
                  </div>
                  <div class="ctrl-group" style="margin-top:0.75rem;">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Value</span><span id="val-splitter-value" style="font-family:var(--font-mono);">30s</span></label>
                    <input type="range" id="splitter-value" class="styled-slider" min="5" max="120" step="5" value="30" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'silence-remover') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Silence Threshold (dB)</span><span id="val-silence-threshold" style="font-family:var(--font-mono);">-40 dB</span></label>
                    <input type="range" id="silence-threshold" class="styled-slider" min="-80" max="-20" step="2" value="-40" style="width:100%;">
                  </div>
                  <div class="ctrl-group" style="margin-top:0.75rem;">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Min Duration (s)</span><span id="val-silence-duration" style="font-family:var(--font-mono);">0.5s</span></label>
                    <input type="range" id="silence-duration" class="styled-slider" min="0.1" max="3" step="0.1" value="0.5" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'audio-looper') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Loop Count</span><span id="val-loop-count" style="font-family:var(--font-mono);">3x</span></label>
                    <input type="range" id="loop-count" class="styled-slider" min="2" max="10" step="1" value="3" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'audio-pan') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Pan Balance</span><span id="val-pan-value" style="font-family:var(--font-mono);">Center</span></label>
                    <input type="range" id="pan-value" class="styled-slider" min="-1" max="1" step="0.1" value="0" style="width:100%;">
                  </div>
                <% } else if (tool.tool_key === 'audio-resampler') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label">Target Sample Rate</label>
                    <select id="resampler-rate" class="styled-select">
                      <option value="44100">44.1 kHz (CD Quality)</option>
                      <option value="48000">48.0 kHz (Studio Quality)</option>
                      <option value="22050">22.05 kHz (Speech/Low-Fi)</option>
                      <option value="8000">8.0 kHz (Telephone/Lowest)</option>
                    </select>
                  </div>
                <% } else if (tool.tool_key === 'stereo-widener') { %>
                  <div class="ctrl-group">
                    <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Stereo Widening Level</span><span id="val-widener-level" style="font-family:var(--font-mono);">50%</span></label>
                    <input type="range" id="widener-level" class="styled-slider" min="0" max="100" step="5" value="50" style="width:100%;">
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- STEP 3: CONVERT -->
      <div class="cv-step disabled" id="step-3-section">
        <div class="cv-step-num">
          <span>3</span>
        </div>
        <div class="cv-step-body">
          <h3 class="cv-step-title">Convert & Download</h3>

          <button class="btn-main-action" id="btn-process-audio">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89M4 4l4 4" /></svg>
            Convert & Render
          </button>

          <!-- Progress -->
          <div class="cv-progress hidden" id="processing-card">
            <div class="cv-progress-label">
              <span id="processing-status">Processing...</span>
              <span id="processing-detail" style="font-size:0.75rem; color:var(--text-muted);"></span>
            </div>
            <div class="cv-progress-track">
              <div id="processing-progress-bar" class="cv-progress-fill" style="width:10%;"></div>
            </div>
          </div>

          <!-- Success / Download -->
          <div class="cv-download hidden" id="download-card">
            <div class="cv-download-check">
              <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
            </div>
            <div class="cv-download-meta">
              <strong>Conversion Complete!</strong>
              <span id="download-file-size">-- KB</span>
            </div>
            <a href="" id="download-link" download class="btn-download">
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
              Download File
            </a>
          </div>
        </div>
      </div>

    </div><!-- end .converter-ui -->
  <% } %>

</div><!-- end .audio-workbench -->

<!-- GENERATOR OPTIONS MODAL -->
<% if (isGenerator) { %>
  <div class="modal-backdrop" id="config-modal-backdrop">
    <div class="modal-container">
      <div class="modal-header">
        <h3><%= tool.name %> Settings</h3>
        <button class="modal-close" id="config-modal-close-btn">&times;</button>
      </div>
      <div class="modal-body">
        <% if (tool.tool_key === 'blank-mp3') { %>
          <div class="ctrl-group">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Silence Duration (s)</span><span id="val-blank-duration" style="font-family:var(--font-mono);">10.0s</span></label>
            <input type="range" id="blank-duration" class="styled-slider" min="1" max="120" step="1" value="10" style="margin-top:0.5rem; width:100%;">
          </div>
        <% } else if (tool.tool_key === 'white-noise') { %>
          <div class="ctrl-group">
            <label class="ctrl-label">Noise Style</label>
            <select id="noise-color" class="styled-select">
              <option value="white">White Noise (Static Hiss)</option>
              <option value="pink">Pink Noise (Waterfall)</option>
              <option value="brown">Brown Noise (Deep Rumble)</option>
            </select>
          </div>
          <div class="ctrl-group" style="margin-top:1rem;">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Duration (s)</span><span id="val-noise-duration" style="font-family:var(--font-mono);">5.0s</span></label>
            <input type="range" id="noise-duration" class="styled-slider" min="1" max="60" step="1" value="5" style="margin-top:0.5rem; width:100%;">
          </div>

        <% } else if (tool.tool_key === 'metronome') { %>
          <div class="ctrl-group">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Tempo (BPM)</span><span id="val-metronome-bpm" style="font-family:var(--font-mono);">120 BPM</span></label>
            <input type="range" id="metronome-bpm" class="styled-slider" min="40" max="240" step="1" value="120" style="margin-top:0.5rem; width:100%;">
          </div>
          <div class="ctrl-group" style="margin-top:1rem;">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Duration (s)</span><span id="val-metronome-duration" style="font-family:var(--font-mono);">10.0s</span></label>
            <input type="range" id="metronome-duration" class="styled-slider" min="1" max="60" step="1" value="10" style="margin-top:0.5rem; width:100%;">
          </div>
        <% } %>
      </div>
      <div class="modal-footer">
        <button class="btn btn-primary" id="config-modal-save-btn">Apply Settings</button>
      </div>
    </div>
  </div>
<% } %>


