<div class="audio-workbench" data-tool-key="<%= tool.tool_key %>" data-tool-category="<%= tool.category %>">
  
  <!-- WORKBENCH HEADER WITH DESCRIPTION -->
  <div class="card intro-card" style="margin-bottom: 2rem; border-left: 4px solid var(--accent-primary);">
    <h3 style="font-family: var(--font-heading); font-size: 1.2rem; color: var(--text-primary); margin-bottom: 0.5rem;">
      <%= tool.h1 || tool.name %>
    </h3>
    <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6;">
      <%= tool.intro_paragraph || tool.page_description %>
    </p>
  </div>

  <!-- WORK AREA -->
  <div class="grid-layout" style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; margin-bottom: 2.5rem;">
    
    <!-- LEFT PANEL: MEDIA UPLOAD / WAVEFORM VISUALIZER -->
    <div class="left-panel" style="display: flex; flex-direction: column; gap: 2rem;">
      
      <!-- DRAG & DROP FILE ZONE -->
      <% if (!['blank-mp3', 'white-noise', 'frequency-generator', 'metronome', 'text-to-mp3', 'morse-code'].includes(tool.tool_key)) { %>
        <div class="card upload-card" id="drop-zone" style="min-height: 250px; display: flex; flex-direction: column; justify-content: center; align-items: center; border: 2px dashed rgba(255,255,255,0.1); border-radius: var(--radius-lg); background: rgba(255,255,255,0.01); transition: all 0.3s; cursor: pointer; text-align: center; padding: 2rem;">
          <input type="file" id="audio-file-input" style="display: none;" accept="audio/*,video/*">
          <div class="upload-icon-wrapper" style="width: 60px; height: 60px; border-radius: 50%; background: rgba(99, 102, 241, 0.1); display: flex; justify-content: center; align-items: center; margin-bottom: 1.25rem;">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--accent-primary);"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
          </div>
          <h4 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem;">Drag & Drop audio or video here</h4>
          <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">Supports MP3, WAV, OGG, FLAC, M4A, MP4, MOV, etc. (Max 50MB)</p>
          <button class="btn btn-secondary" onclick="document.getElementById('audio-file-input').click()">Browse Files</button>
        </div>
      <% } %>

      <!-- VISUALIZER & PLAYBACK CONTROL SECTION -->
      <div class="card player-card hidden" id="player-section" style="padding: 1.5rem;">
        <div class="player-meta-info" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <span class="file-name-label" id="file-name" style="font-weight: 600; font-size: 0.95rem; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; max-width: 250px;">audio_file.mp3</span>
          <span class="badge" id="file-duration" style="font-family: var(--font-mono); font-size: 0.85rem; background: rgba(255,255,255,0.05); padding: 0.2rem 0.5rem; border-radius: 4px;">00:00</span>
        </div>
        
        <!-- WAVEFORM CANVAS -->
        <div class="canvas-wrapper" style="position: relative; margin-bottom: 1.5rem; height: 120px;">
          <canvas id="visualizer-canvas" height="120" style="width: 100%; height: 100%; border-radius: var(--radius-md); background: rgba(0,0,0,0.15); display: block; border: 1px solid var(--card-border);"></canvas>
          <div class="waveform-overlay" id="waveform-progress" style="position: absolute; top:0; left:0; width:0; height:100%; background: rgba(99, 102, 241, 0.1); pointer-events: none; border-right: 2px solid var(--accent-primary);"></div>
        </div>

        <!-- PLAYBACK BUTTONS -->
        <div class="player-controls" style="display: flex; justify-content: center; align-items: center; gap: 1rem;">
          <button class="btn btn-secondary btn-icon" id="btn-play-pause" title="Play / Pause">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="play-icon"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="pause-icon" class="hidden"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </button>
          <button class="btn btn-secondary btn-icon" id="btn-stop" title="Stop">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10h6v6H9z" /></svg>
          </button>
        </div>
      </div>

    </div>

    <!-- RIGHT PANEL: CONTROLS & EXPORTS -->
    <div class="right-panel" style="display: flex; flex-direction: column; gap: 2rem;">
      
      <!-- SETTINGS AND CONTROLS CARD -->
      <div class="card controls-card" id="settings-card">
        <h3 style="font-family: var(--font-heading); font-size: 1.1rem; margin-bottom: 1.25rem; border-bottom: 1px solid var(--card-border); padding-bottom: 0.75rem;">Tool Settings</h3>
        
        <div id="dynamic-controls-container" style="display: flex; flex-direction: column; gap: 1.25rem;">
          
          <!-- CUTTER / TRIMMER -->
          <% if (tool.tool_key === 'audio-cutter') { %>
            <div class="control-group">
              <label for="trim-start" style="display: flex; justify-content: space-between;">
                <span>Start Time (s)</span>
                <span id="val-trim-start" style="font-family: var(--font-mono);">0.0</span>
              </label>
              <input type="range" id="trim-start" class="styled-range" min="0" max="100" step="0.1" value="0">
            </div>
            <div class="control-group">
              <label for="trim-end" style="display: flex; justify-content: space-between;">
                <span>End Time (s)</span>
                <span id="val-trim-end" style="font-family: var(--font-mono);">10.0</span>
              </label>
              <input type="range" id="trim-end" class="styled-range" min="0" max="100" step="0.1" value="10">
            </div>

          <!-- VOLUME BOOSTER -->
          <% } else if (tool.tool_key === 'volume-booster') { %>
            <div class="control-group">
              <label for="volume-gain" style="display: flex; justify-content: space-between;">
                <span>Volume Level</span>
                <span id="val-volume-gain" style="font-family: var(--font-mono);">200%</span>
              </label>
              <input type="range" id="volume-gain" class="styled-range" min="100" max="500" step="10" value="200">
            </div>

          <!-- SPEED CHANGER -->
          <% } else if (tool.tool_key === 'speed-changer') { %>
            <div class="control-group">
              <label for="speed-factor" style="display: flex; justify-content: space-between;">
                <span>Speed Factor</span>
                <span id="val-speed-factor" style="font-family: var(--font-mono);">1.0x</span>
              </label>
              <input type="range" id="speed-factor" class="styled-range" min="0.5" max="2.0" step="0.05" value="1.0">
            </div>

          <!-- PITCH SHIFTER -->
          <% } else if (tool.tool_key === 'pitch-shifter') { %>
            <div class="control-group">
              <label for="pitch-semitones" style="display: flex; justify-content: space-between;">
                <span>Semitones Pitch</span>
                <span id="val-pitch-semitones" style="font-family: var(--font-mono);">0</span>
              </label>
              <input type="range" id="pitch-semitones" class="styled-range" min="-12" max="12" step="1" value="0">
            </div>

          <!-- BASS BOOSTER -->
          <% } else if (tool.tool_key === 'bass-booster') { %>
            <div class="control-group">
              <label for="bass-gain" style="display: flex; justify-content: space-between;">
                <span>Bass Gain (dB)</span>
                <span id="val-bass-gain" style="font-family: var(--font-mono);">+6 dB</span>
              </label>
              <input type="range" id="bass-gain" class="styled-range" min="0" max="24" step="1" value="6">
            </div>

          <!-- SLOWED & REVERB -->
          <% } else if (tool.tool_key === 'slowed-reverb') { %>
            <div class="control-group">
              <label for="slow-factor" style="display: flex; justify-content: space-between;">
                <span>Speed Slow Down</span>
                <span id="val-slow-factor" style="font-family: var(--font-mono);">0.80x</span>
              </label>
              <input type="range" id="slow-factor" class="styled-range" min="0.5" max="0.95" step="0.01" value="0.80">
            </div>
            <div class="control-group">
              <label for="reverb-mix" style="display: flex; justify-content: space-between;">
                <span>Reverb Level</span>
                <span id="val-reverb-mix" style="font-family: var(--font-mono);">40%</span>
              </label>
              <input type="range" id="reverb-mix" class="styled-range" min="10" max="100" step="5" value="40">
            </div>

          <!-- FADE IN / OUT -->
          <% } else if (tool.tool_key === 'audio-fade') { %>
            <div class="control-group">
              <label for="fade-in" style="display: flex; justify-content: space-between;">
                <span>Fade In Duration (s)</span>
                <span id="val-fade-in" style="font-family: var(--font-mono);">2.0s</span>
              </label>
              <input type="range" id="fade-in" class="styled-range" min="0" max="10" step="0.5" value="2.0">
            </div>
            <div class="control-group">
              <label for="fade-out" style="display: flex; justify-content: space-between;">
                <span>Fade Out Duration (s)</span>
                <span id="val-fade-out" style="font-family: var(--font-mono);">2.0s</span>
              </label>
              <input type="range" id="fade-out" class="styled-range" min="0" max="10" step="0.5" value="2.0">
            </div>

          <!-- VOICE CHANGER -->
          <% } else if (tool.tool_key === 'voice-changer') { %>
            <div class="control-group">
              <label for="voice-preset">Select Voice Style</label>
              <select id="voice-preset" class="styled-select">
                <option value="chipmunk">Chipmunk (High Pitch)</option>
                <option value="monster">Monster (Deep Pitch)</option>
                <option value="robot">Robot Synth (Vocoder)</option>
                <option value="helium">Helium Gas</option>
                <option value="echo">Cave Echo</option>
              </select>
            </div>

          <!-- TEXT TO MP3 -->
          <% } else if (tool.tool_key === 'text-to-mp3') { %>
            <div class="control-group">
              <label for="tts-text">Text Content</label>
              <textarea id="tts-text" class="pane-textarea" style="min-height: 100px; font-size: 0.9rem;" placeholder="Type the message you want to speak..."></textarea>
            </div>
            <div class="control-group">
              <label for="tts-rate" style="display: flex; justify-content: space-between;">
                <span>Speaking Rate</span>
                <span id="val-tts-rate" style="font-family: var(--font-mono);">1.0x</span>
              </label>
              <input type="range" id="tts-rate" class="styled-range" min="0.5" max="2.0" step="0.1" value="1.0">
            </div>

          <!-- MORSE CODE -->
          <% } else if (tool.tool_key === 'morse-code') { %>
            <div class="control-group">
              <label for="morse-text">Input Text</label>
              <input type="text" id="morse-text" class="styled-input" placeholder="Type text (e.g. SOS)" value="SOS">
            </div>
            <div class="control-group">
              <label for="morse-wpm" style="display: flex; justify-content: space-between;">
                <span>Speed (WPM)</span>
                <span id="val-morse-wpm" style="font-family: var(--font-mono);">15 WPM</span>
              </label>
              <input type="range" id="morse-wpm" class="styled-range" min="5" max="40" step="1" value="15">
            </div>

          <!-- METRONOME -->
          <% } else if (tool.tool_key === 'metronome') { %>
            <div class="control-group">
              <label for="metronome-bpm" style="display: flex; justify-content: space-between;">
                <span>Tempo (BPM)</span>
                <span id="val-metronome-bpm" style="font-family: var(--font-mono);">120 BPM</span>
              </label>
              <input type="range" id="metronome-bpm" class="styled-range" min="40" max="240" step="1" value="120">
            </div>

          <!-- FREQUENCY GENERATOR -->
          <% } else if (tool.tool_key === 'frequency-generator') { %>
            <div class="control-group">
              <label for="wave-type">Wave Form</label>
              <select id="wave-type" class="styled-select">
                <option value="sine">Sine Wave (Pure Tone)</option>
                <option value="square">Square Wave (Retro Sound)</option>
                <option value="triangle">Triangle Wave (Soft Tone)</option>
                <option value="sawtooth">Sawtooth Wave (Buzz Tone)</option>
              </select>
            </div>
            <div class="control-group">
              <label for="wave-freq" style="display: flex; justify-content: space-between;">
                <span>Frequency (Hz)</span>
                <span id="val-wave-freq" style="font-family: var(--font-mono);">440 Hz</span>
              </label>
              <input type="range" id="wave-freq" class="styled-range" min="100" max="2000" step="5" value="440">
            </div>

          <!-- WHITE NOISE GENERATOR -->
          <% } else if (tool.tool_key === 'white-noise') { %>
            <div class="control-group">
              <label for="noise-color">Noise Style</label>
              <select id="noise-color" class="styled-select">
                <option value="white">White Noise (Static Hiss)</option>
                <option value="pink">Pink Noise (Waterfall)</option>
                <option value="brown">Brown Noise (Deep Rumble)</option>
              </select>
            </div>
            
          <!-- AUDIO BITRATE CHANGER -->
          <% } else if (tool.tool_key === 'bitrate-changer' || tool.category === 'Audio Compressors') { %>
            <div class="control-group">
              <label for="audio-bitrate">Output Bitrate</label>
              <select id="audio-bitrate" class="styled-select">
                <option value="320">320 kbps (High Quality)</option>
                <option value="256">256 kbps (Medium-High)</option>
                <option value="192">192 kbps (Standard)</option>
                <option value="128">128 kbps (Low Size)</option>
              </select>
            </div>

          <!-- DEFAULT/GENERIC CONVERTER CONTROLS -->
          <% } else { %>
            <div class="control-group">
              <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; margin: 0;">
                No adjustments needed. Uploading an audio file will automatically configure the audio decoder for optimal conversion to the destination format.
              </p>
            </div>
          <% } %>
        </div>

        <!-- PROCESS ACTION BUTTON -->
        <button class="btn btn-primary btn-full" id="btn-process-audio" style="margin-top: 1.5rem;" <%= ['blank-mp3', 'white-noise', 'frequency-generator', 'metronome', 'text-to-mp3', 'morse-code'].includes(tool.tool_key) ? '' : 'disabled' %>>
          Process & Convert Audio
        </button>
      </div>

      <!-- PROCESSING INDICATOR CARD -->
      <div class="card player-card hidden" id="processing-card" style="padding: 1.5rem; text-align: center;">
        <h4 style="font-size: 1.05rem; font-weight: 600; margin-bottom: 0.75rem;" id="processing-status">Processing Audio...</h4>
        <div class="loader-bar" style="width: 100%; height: 6px; border-radius: 3px; background: rgba(255,255,255,0.05); overflow: hidden; position: relative;">
          <div class="loader-progress" id="processing-progress-bar" style="width: 10%; height: 100%; background: var(--accent-primary); border-radius: 3px; transition: width 0.15s;"></div>
        </div>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem;" id="processing-detail">Reading original audio packets...</p>
      </div>

      <!-- DOWNLOAD OUTPUT SECTION -->
      <div class="card player-card hidden" id="download-card" style="padding: 1.5rem; border: 1px solid rgba(16, 185, 129, 0.2); background: rgba(16, 185, 129, 0.01);">
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem;">
          <div style="width: 44px; height: 44px; border-radius: 50%; background: rgba(16, 185, 129, 0.1); color: var(--success); display: flex; justify-content: center; align-items: center;">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
          </div>
          <div>
            <h4 style="font-size: 1.05rem; font-weight: 600; color: var(--text-primary);">Processing Complete!</h4>
            <p style="font-size: 0.85rem; color: var(--text-secondary);" id="download-file-size">File size: -- KB</p>
          </div>
        </div>
        <a href="" id="download-link" download class="btn btn-success btn-full" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem;">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Download File
        </a>
      </div>

    </div>
  </div>

  <!-- ABOUT & DETAILS CMS CONTAINER (SEO BOOSTER) -->
  <% if (tool.content_heading && tool.content_paragraph) { %>
    <div class="card seo-content-card" style="margin-bottom: 2.5rem; line-height: 1.7;">
      <h3 style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--text-primary); margin-bottom: 1rem;">
        <%= tool.content_heading %>
      </h3>
      <p style="color: var(--text-secondary); font-size: 0.95rem;">
        <%= tool.content_paragraph %>
      </p>
    </div>
  <% } %>

</div>
