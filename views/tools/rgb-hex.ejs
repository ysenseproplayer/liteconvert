<div class="grid-layout">
  <div class="card">
    <h3>RGB to HEX</h3>
    <div class="settings-row">
      <div class="settings-group"><label for="rgb-r">Red (0-255)</label><input type="number" id="rgb-r" class="styled-input" value="99" min="0" max="255"></div>
      <div class="settings-group"><label for="rgb-g">Green (0-255)</label><input type="number" id="rgb-g" class="styled-input" value="102" min="0" max="255"></div>
      <div class="settings-group"><label for="rgb-b">Blue (0-255)</label><input type="number" id="rgb-b" class="styled-input" value="241" min="0" max="255"></div>
    </div>
    <div class="settings-group" style="margin-top:1.5rem;"><label>HEX Color Code</label><input type="text" id="hex-output" class="styled-input mono" readonly></div>
  </div>
  <div class="card" style="display:flex; flex-direction:column; justify-content:center; align-items:center;">
    <h3>Color Preview</h3>
    <div id="rgb-preview-box" style="width:150px; height:150px; border-radius:var(--radius-lg); border:4px solid var(--card-border); box-shadow:var(--shadow-md); margin:1.5rem 0; background-color:rgb(99,102,241);"></div>
  </div>
</div>
