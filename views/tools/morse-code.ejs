<div class="morse-clone-wrapper" data-tool-key="morse-code">
  <div style="text-align: center; margin-bottom: 2rem;">
    <h1 style="font-family: var(--font-heading); font-size: 2.25rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.5rem;">Morse Code Translator</h1>
    <p style="font-size: 1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Translate text to Morse code and listen to the audio generation instantly.</p>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2.5rem;" class="split-pane">
    <!-- Left Input Box -->
    <div class="card pane-card" style="min-height: 250px;">
      <div class="pane-header">
        <span>Input Text</span>
        <button class="text-btn" id="morse-btn-clear">Clear</button>
      </div>
      <textarea id="morse-input-text" class="pane-textarea" style="flex-grow: 1; min-height: 180px; font-size: 1.1rem; line-height: 1.6;" placeholder="Type text to translate here...">SOS</textarea>
    </div>

    <!-- Right Output Box -->
    <div class="card pane-card" style="min-height: 250px;">
      <div class="pane-header">
        <span>Morse Code Output</span>
        <button class="text-btn secondary" id="morse-btn-copy">Copy Code</button>
      </div>
      <textarea id="morse-output-text" class="pane-textarea mono" style="flex-grow: 1; min-height: 180px; font-size: 1.25rem; letter-spacing: 2px; line-height: 1.6;" readonly placeholder="... --- ..."></textarea>
    </div>
  </div>

  <!-- Speed control and audio playback bar -->
  <div class="card" style="padding: 1.5rem; margin-bottom: 2.5rem;">
    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 2rem;">
      <!-- Speed Slider -->
      <div style="flex-grow: 1; min-width: 250px; display: flex; flex-direction: column; gap: 0.5rem;">
        <label for="morse-speed" style="display: flex; justify-content: space-between; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">
          <span>Morse Speed (WPM)</span>
          <span id="val-morse-speed" style="color: var(--accent-primary); font-family: var(--font-mono);">15 WPM</span>
        </label>
        <input type="range" id="morse-speed" class="styled-slider" min="5" max="40" step="1" value="15" style="width: 100%;">
      </div>

      <!-- Toolbar Buttons -->
      <div style="display: flex; gap: 0.75rem;">
        <button class="btn btn-secondary" id="morse-btn-play" style="display: flex; align-items: center; gap: 0.35rem;">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /></svg>
          Play Sound
        </button>
        <button class="btn btn-secondary hidden" id="morse-btn-stop" style="display: flex; align-items: center; gap: 0.35rem; color: var(--danger); border-color: rgba(239, 68, 68, 0.2);">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 10h6v6H9z" /></svg>
          Stop
        </button>
        <button class="btn btn-primary" id="morse-btn-download" style="display: flex; align-items: center; gap: 0.35rem; background: var(--accent-gradient);">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Download Audio (MP3)
        </button>
      </div>
    </div>
  </div>
</div>
