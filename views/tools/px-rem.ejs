<div class="grid-layout">
  <div class="card">
    <h3>Pixel to REM Converter</h3>
    <div class="settings-group">
      <label for="px-base">Base Font Size (px)</label>
      <input type="number" id="px-base" class="styled-input" value="16" min="1" max="100">
    </div>
    
    <div class="settings-row" style="margin-top: 1.5rem;">
      <div class="settings-group">
        <label for="px-input">Pixels (px)</label>
        <input type="number" id="px-input" class="styled-input" value="16">
      </div>
      <div class="settings-group">
        <label for="rem-input">REM (rem)</label>
        <input type="number" id="rem-input" class="styled-input" value="1" step="0.0625">
      </div>
    </div>
  </div>

  <div class="card">
    <h3>Quick Conversion Table (16px base)</h3>
    <div style="max-height: 250px; overflow-y: auto;">
      <table class="admin-table" style="font-size: 0.85rem;">
        <thead>
          <tr>
            <th>PX</th>
            <th>REM</th>
          </tr>
        </thead>
        <tbody id="px-rem-table-body">
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>
  </div>
</div>
