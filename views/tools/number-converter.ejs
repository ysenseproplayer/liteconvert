<div class="card" style="display:flex; flex-direction:column; gap:1.25rem;">
  <h3>Number Base Converter (Bidirectional)</h3>
  <div class="settings-group"><label for="base-dec">Decimal (Base 10)</label><input type="text" id="base-dec" class="styled-input mono" value="255"></div>
  <div class="settings-group"><label for="base-bin">Binary (Base 2)</label><input type="text" id="base-bin" class="styled-input mono" value="11111111"></div>
  <div class="settings-group"><label for="base-hex">Hexadecimal (Base 16)</label><input type="text" id="base-hex" class="styled-input mono" value="ff"></div>
  <div class="settings-group"><label for="base-oct">Octal (Base 8)</label><input type="text" id="base-oct" class="styled-input mono" value="377"></div>
</div>
