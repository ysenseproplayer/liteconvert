<div class="split-pane">
  <div class="card pane-card">
    <div class="pane-header"><span>Raw SVG Markup</span><button class="text-btn" id="btn-clear-svg">Clear</button></div>
    <textarea id="svg-input" class="pane-textarea mono" placeholder="Paste SVG markup here... e.g. <svg>...</svg>" style="min-height:350px;"></textarea>
  </div>
  <div class="card pane-card flex-col">
    <div class="pane-header"><span>Optimized SVG Markup</span><button class="text-btn success" id="btn-copy-svg">Copy</button></div>
    <textarea id="svg-output" class="pane-textarea mono" readonly placeholder="Optimized code will load here..." style="min-height:270px;"></textarea>
    <button class="btn btn-primary btn-full mt-lg" id="btn-optimize-svg">Optimize SVG</button>
  </div>
</div>
