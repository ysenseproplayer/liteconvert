<!-- Cover Art Adder Tool -->
<div class="audio-workbench" data-tool-key="cover-art" data-tool-category="utilities">
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
    </div>
    <div class="tool-hero-text"><p class="tool-hero-desc"><%= tool.intro_paragraph || tool.page_description %></p></div>
    <div class="tool-hero-badges">
      <span class="hero-badge">100% Free</span>
      <span class="hero-badge">Privacy Safe</span>
      <span class="hero-badge">Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 700px; margin: 0 auto;">

    <!-- Two-column upload area -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">

      <!-- MP3 Upload -->
      <div class="tool-panel">
        <div class="panel-label">Step 1 — Upload MP3</div>
        <div id="ca-mp3-drop" class="cv-dropzone" style="margin-top: 0.75rem; min-height: 100px;">
          <input type="file" id="ca-mp3-input" style="display:none;" accept=".mp3,audio/mpeg">
          <div class="cv-dropzone-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg></div>
          <div class="cv-dropzone-text"><strong>Drop MP3 here</strong><span>or click to browse</span></div>
        </div>
        <div id="ca-mp3-info" class="hidden" style="margin-top: 0.75rem; font-size: 0.85rem; color: var(--text-secondary); word-break: break-all;"></div>
      </div>

      <!-- Image Upload -->
      <div class="tool-panel">
        <div class="panel-label">Step 2 — Upload Cover Art</div>
        <div id="ca-img-drop" class="cv-dropzone" style="margin-top: 0.75rem; min-height: 100px;">
          <input type="file" id="ca-img-input" style="display:none;" accept=".jpg,.jpeg,.png,image/jpeg,image/png">
          <div class="cv-dropzone-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>
          <div class="cv-dropzone-text"><strong>Drop JPG/PNG here</strong><span>or click to browse</span></div>
        </div>
        <div id="ca-img-preview-wrap" class="hidden" style="margin-top: 0.75rem; text-align: center;">
          <img id="ca-img-preview" src="" alt="Cover Preview" style="max-width: 100%; max-height: 120px; border-radius: 8px; border: 1px solid var(--card-border); object-fit: cover;">
        </div>
      </div>
    </div>

    <!-- Embed button -->
    <button id="ca-btn-embed" class="btn-main-action" style="width: 100%; margin-bottom: 1.5rem;" disabled>
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
      Add Cover Art to MP3
    </button>

    <!-- Result card -->
    <div id="ca-result-card" class="tool-panel hidden" style="text-align: center; padding: 2rem; border: 1px solid rgba(16,185,129,0.2); background: rgba(16,185,129,0.02);">
      <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--success); margin: 0 auto 1rem; display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <h3 style="font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Cover Art Embedded!</h3>
      <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Your MP3 file now has cover artwork embedded using ID3v2 APIC frame.</p>
      <a id="ca-download-link" href="" download class="btn btn-success" style="background: var(--success); color: white; padding: 0.75rem 2rem; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download MP3 with Cover
      </a>
    </div>

  </div>
</div>


