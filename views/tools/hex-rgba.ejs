<div class="grid-layout">
  <div class="card">
    <h3>HEX to RGBA / HSLA</h3>
    <div class="settings-group"><label for="hex-val">HEX Color Code</label><input type="text" id="hex-val" class="styled-input" value="#6366f1" placeholder="#6366f1"></div>
    <div class="settings-group" style="margin-top:1rem;"><label for="hex-opacity">Opacity</label><input type="range" id="hex-opacity" min="0" max="100" value="100" class="styled-slider"></div>
    <div class="settings-group" style="margin-top:1.5rem;"><label>RGBA Color Code</label><input type="text" id="rgba-output" class="styled-input mono" readonly></div>
    <div class="settings-group"><label>HSLA Color Code</label><input type="text" id="hsla-output" class="styled-input mono" readonly></div>
  </div>
  <div class="card" style="display:flex; flex-direction:column; justify-content:center; align-items:center;">
    <h3>Color Preview</h3>
    <div id="color-preview-box" style="width:150px; height:150px; border-radius:var(--radius-lg); border:4px solid var(--card-border); box-shadow:var(--shadow-md); margin:1.5rem 0; background-color:#6366f1;"></div>
  </div>
</div>
