<div class="card">
  <h3>Timezone Converter & Comparison</h3>
  <p class="card-desc">Compare current local times across standard timezone offsets.</p>
  <div style="display:flex; flex-direction:column; gap:1.25rem; margin-top:1rem;">
    <div class="settings-row">
      <div class="settings-group"><label>Greenwich Mean Time (GMT/UTC)</label><input type="text" id="tz-gmt" class="styled-input mono" readonly></div>
      <div class="settings-group"><label>Eastern Standard Time (EST - UTC-5)</label><input type="text" id="tz-est" class="styled-input mono" readonly></div>
    </div>
    <div class="settings-row">
      <div class="settings-group"><label>India Standard Time (IST - UTC+5.5)</label><input type="text" id="tz-ist" class="styled-input mono" readonly></div>
      <div class="settings-group"><label>Pacific Standard Time (PST - UTC-8)</label><input type="text" id="tz-pst" class="styled-input mono" readonly></div>
    </div>
  </div>
</div>
