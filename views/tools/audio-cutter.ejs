<div class="mp3cut-clone-wrapper" data-tool-key="audio-cutter">
  <div style="text-align: center; margin-bottom: 2rem;">
    <h1 style="font-family: var(--font-heading); font-size: 2.25rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.5rem;">Audio Cutter & Trimmer</h1>
    <p style="font-size: 1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto;">Cut and trim your MP3/WAV audio files online. Free, fast, and secure local audio tool.</p>
  </div>

  <!-- UPLOAD BOX (shown initially) -->
  <div class="card mp3cut-upload-card" id="mc-drop-zone" style="max-width: 680px; margin: 0 auto 3rem; min-height: 250px; display: flex; flex-direction: column; justify-content: center; align-items: center; border: 2px dashed rgba(0, 242, 254, 0.25); border-radius: 16px; background-color: rgba(18, 22, 32, 0.4); text-align: center; padding: 3rem; cursor: pointer; transition: all 0.3s;">
    <input type="file" id="mc-file-input" style="display: none;" accept="audio/*,video/*">
    <div style="width: 64px; height: 64px; border-radius: 50%; background-color: rgba(0, 242, 254, 0.08); display: flex; justify-content: center; align-items: center; margin-bottom: 1.25rem; color: var(--accent-primary);">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
    </div>
    <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 0.5rem;">Upload File to Cut</h3>
    <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem;">Supports MP3, WAV, FLAC, M4A, etc.</p>
    <button class="btn btn-primary" onclick="document.getElementById('mc-file-input').click()" style="background: var(--accent-gradient);">Browse Files</button>
  </div>

  <!-- DEDICATED WAVEFORM CUTTER WORKSPACE (hidden initially) -->
  <div class="card hidden" id="mc-editor-panel" style="max-width: 800px; margin: 0 auto 3rem; padding: 2rem;">
    <!-- Meta label -->
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem;">
      <span id="mc-file-name" style="font-weight: 600; font-size: 1rem; color: var(--text-primary); text-overflow: ellipsis; overflow: hidden; white-space: nowrap; max-width: 350px;">audio_track.mp3</span>
      <span class="badge" id="mc-file-duration" style="font-family: var(--font-mono); font-size: 0.85rem; background: rgba(255,255,255,0.05); padding: 0.2rem 0.5rem; border-radius: 4px;">00:00</span>
    </div>

    <!-- Canvas wave area with drag overlay handles -->
    <div style="position: relative; height: 160px; margin-bottom: 2rem;">
      <canvas id="mc-canvas" height="160" style="width: 100%; height: 100%; border-radius: 8px; background: rgba(0,0,0,0.2); display: block; border: 1px solid var(--card-border);"></canvas>
      <div id="mc-waveform-progress" style="position: absolute; top:0; left:0; width:0%; height:100%; background: rgba(0, 242, 254, 0.08); pointer-events: none;"></div>
      
      <!-- Visually draggable handle elements overlays -->
      <div class="mc-drag-handle left" id="mc-handle-start" style="position: absolute; top: 0; left: 10%; width: 14px; height: 100%; background: var(--accent-gradient); cursor: ew-resize; border-radius: 4px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 10px rgba(0,242,254,0.4);">
        <div style="width: 2px; height: 20px; background: white; opacity: 0.7;"></div>
      </div>
      <div class="mc-drag-handle right" id="mc-handle-end" style="position: absolute; top: 0; left: 80%; width: 14px; height: 100%; background: var(--accent-gradient); cursor: ew-resize; border-radius: 4px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 10px rgba(0,242,254,0.4);">
        <div style="width: 2px; height: 20px; background: white; opacity: 0.7;"></div>
      </div>
    </div>

    <!-- Sliders and numeric time intervals -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;" class="split-pane">
      <div style="display: flex; flex-direction: column; gap: 0.4rem;">
        <label style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">Start Time</label>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <input type="number" id="mc-input-start" class="styled-input" step="0.1" min="0" value="0.0">
          <span style="color: var(--text-muted);">sec</span>
        </div>
      </div>
      <div style="display: flex; flex-direction: column; gap: 0.4rem;">
        <label style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">End Time</label>
        <div style="display: flex; align-items: center; gap: 0.5rem;">
          <input type="number" id="mc-input-end" class="styled-input" step="0.1" min="0" value="10.0">
          <span style="color: var(--text-muted);">sec</span>
        </div>
      </div>
    </div>

    <!-- Playback and Fade options -->
    <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1.5rem; margin-bottom: 2rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem;">
      <div style="display: flex; gap: 0.75rem;">
        <button class="btn btn-secondary" id="mc-btn-play" style="display: flex; align-items: center; gap: 0.35rem;">
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="mc-play-icon"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /></svg>
          <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="mc-pause-icon" class="hidden"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Preview Cut
        </button>
        <button class="btn btn-secondary" id="mc-btn-stop">Stop</button>
      </div>

      <!-- Fades -->
      <div style="display: flex; gap: 1rem;">
        <label class="checkbox-container">
          Fade In
          <input type="checkbox" id="mc-fade-in" checked>
          <span class="checkmark"></span>
        </label>
        <label class="checkbox-container">
          Fade Out
          <input type="checkbox" id="mc-fade-out" checked>
          <span class="checkmark"></span>
        </label>
      </div>
    </div>

    <!-- Final actions -->
    <div style="display: flex; justify-content: flex-end; gap: 1rem;">
      <button class="btn btn-secondary" id="mc-btn-reset">Reset File</button>
      <button class="btn btn-primary" id="mc-btn-cut" style="background: var(--accent-gradient); min-width: 140px;">Cut & Save</button>
    </div>
  </div>

  <!-- Processing State -->
  <div class="card hidden" id="mc-processing-panel" style="max-width: 800px; margin: 0 auto 3rem; padding: 2rem; text-align: center;">
    <h4 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 0.75rem;">Rendering audio trim track...</h4>
    <div style="width: 100%; height: 6px; background-color: rgba(255,255,255,0.03); border-radius: 3px; overflow: hidden; position: relative;">
      <div id="mc-progress-bar" style="width: 10%; height: 100%; background: var(--accent-gradient); border-radius: 3px; transition: width 0.15s;"></div>
    </div>
  </div>

  <!-- Download output panel -->
  <div class="card hidden" id="mc-success-panel" style="max-width: 800px; margin: 0 auto 3rem; padding: 2.5rem; text-align: center; border: 1px solid rgba(16, 185, 129, 0.2); background-color: rgba(16, 185, 129, 0.02);">
    <div style="width: 60px; height: 60px; border-radius: 50%; background-color: rgba(16, 185, 129, 0.1); color: var(--success); display: flex; justify-content: center; align-items: center; margin: 0 auto 1.25rem;">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
    </div>
    <h3 style="font-size: 1.35rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-primary);">Audio Trimmed Successfully!</h3>
    <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.75rem;" id="mc-output-info">Output Format: MP3 | File Size: -- KB</p>
    <div style="display: flex; gap: 1rem; justify-content: center;">
      <button class="btn btn-secondary" id="mc-btn-edit-again">Edit Again</button>
      <a href="" id="mc-download-link" download class="btn btn-success" style="background-color: var(--success); color: white; padding: 0.8rem 2rem; display: inline-flex; align-items: center; gap: 0.5rem; font-size: 1rem; border-radius: 8px; box-shadow: 0 4px 15px rgba(16, 185, 129, 0.2);">
        <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download File (MP3)
      </a>
    </div>
  </div>
</div>
