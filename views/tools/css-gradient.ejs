<div class="grid-layout">
  <div class="card">
    <h3>CSS Gradient Settings</h3>
    <div class="settings-row">
      <div class="settings-group"><label for="grad-color-1">Start Color</label><input type="text" id="grad-color-1" class="styled-input" value="#6366f1"></div>
      <div class="settings-group"><label for="grad-color-2">End Color</label><input type="text" id="grad-color-2" class="styled-input" value="#8b5cf6"></div>
    </div>
    <div class="settings-group" style="margin-top:1rem;"><label for="grad-angle">Gradient Angle (deg)</label><input type="number" id="grad-angle" class="styled-input" value="135" min="0" max="360"></div>
  </div>
  <div class="card pane-card">
    <div class="pane-header"><span>CSS Gradient Output</span><button class="text-btn success" id="btn-copy-grad">Copy CSS</button></div>
    <textarea id="grad-css-output" class="pane-textarea mono" readonly style="min-height:100px; font-size:0.85rem; margin:1rem 0;"></textarea>
    <div id="grad-preview-box" style="height:100px; border-radius:var(--radius-md); border:1px solid var(--card-border); background:linear-gradient(135deg, #6366f1, #8b5cf6);"></div>
  </div>
</div>
