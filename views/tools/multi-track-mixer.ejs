<!-- Multi-Track Audio Mixer Tool -->
<div class="audio-workbench" data-tool-key="multi-track-mixer" data-tool-category="editors">
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
    </div>
    <div class="tool-hero-text">
      <p class="tool-hero-desc"><%= tool.seo_meta_desc %></p>
    </div>
    <div class="tool-hero-badges">
      <span class="hero-badge">100% Free</span>
      <span class="hero-badge">Privacy Safe</span>
      <span class="hero-badge">Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 700px; margin: 0 auto;">

    <!-- Dual track panels -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;" class="split-pane">
      
      <!-- Track 1: Voiceover / Vocals -->
      <div class="tool-panel">
        <div class="panel-label">Track 1 — Vocals / Voice</div>
        <div id="mx-drop-1" class="cv-dropzone" style="margin-top: 0.75rem; min-height: 110px;">
          <input type="file" id="mx-input-1" style="display:none;" accept="audio/*">
          <div class="cv-dropzone-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" /></svg></div>
          <div class="cv-dropzone-text"><strong>Voice track</strong><span>Drop or browse</span></div>
        </div>
        <div id="mx-info-1" class="hidden" style="margin-top: 0.75rem; font-size: 0.82rem; color: var(--text-secondary); word-break: break-all;"></div>
        
        <!-- Track 1 Volume -->
        <div id="mx-vol-wrap-1" class="hidden" style="margin-top: 1rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 0.75rem;">
          <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Track 1 Volume</span><span id="mx-val-1">100%</span></label>
          <input type="range" id="mx-vol-1" class="styled-slider" min="0" max="200" step="5" value="100" style="width:100%; margin-top:0.35rem;">
        </div>
      </div>

      <!-- Track 2: Background Music / Instrumental -->
      <div class="tool-panel">
        <div class="panel-label">Track 2 — Background Music</div>
        <div id="mx-drop-2" class="cv-dropzone" style="margin-top: 0.75rem; min-height: 110px;">
          <input type="file" id="mx-input-2" style="display:none;" accept="audio/*">
          <div class="cv-dropzone-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg></div>
          <div class="cv-dropzone-text"><strong>Music track</strong><span>Drop or browse</span></div>
        </div>
        <div id="mx-info-2" class="hidden" style="margin-top: 0.75rem; font-size: 0.82rem; color: var(--text-secondary); word-break: break-all;"></div>

        <!-- Track 2 Volume -->
        <div id="mx-vol-wrap-2" class="hidden" style="margin-top: 1rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 0.75rem;">
          <label class="ctrl-label" style="display:flex; justify-content:space-between;"><span>Track 2 Volume</span><span id="mx-val-2">70%</span></label>
          <input type="range" id="mx-vol-2" class="styled-slider" min="0" max="200" step="5" value="70" style="width:100%; margin-top:0.35rem;">
        </div>
      </div>
    </div>

    <!-- Master Mix Action Button -->
    <button id="mx-btn-mix" class="btn-main-action" style="width: 100%; margin-bottom: 1.5rem;" disabled>
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
      Mix & Export Tracks
    </button>

    <!-- Processing status -->
    <div id="mx-processing-card" class="tool-panel hidden" style="text-align: center; padding: 2rem; margin-bottom: 1.5rem;">
      <div id="mx-status" style="font-size: 1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 1rem;">Mixing audio buffers...</div>
      <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
        <div id="mx-progress" style="width: 30%; height: 100%; background: var(--accent-gradient); border-radius: 3px; transition: width 0.3s;"></div>
      </div>
    </div>

    <!-- Output preview download panel -->
    <div id="mx-result-card" class="tool-panel hidden" style="text-align: center; padding: 2rem; border: 1px solid rgba(16,185,129,0.2); background: rgba(16,185,129,0.02);">
      <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--success); margin:0 auto 1rem; display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Audio Mix Complete!</h3>
      <p id="mx-output-info" style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Your master audio mix is ready to play and download.</p>
      
      <!-- Integrated Audio Player -->
      <audio id="mx-preview-player" controls style="width:100%; margin-bottom: 1.5rem;"></audio>
      <br>
      <a id="mx-download-link" href="" download class="btn btn-success" style="background: var(--success); color: white; padding: 0.75rem 2rem; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download Master Mix
      </a>
    </div>

  </div>
</div>
