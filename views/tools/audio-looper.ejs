<!-- Custom Audio Looper Workspace -->
<div class="audio-workbench" data-tool-key="audio-looper" data-tool-category="editors">
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 8H17m-.5 8.5V20m0 0l-4-4m4 4l4-4" /></svg>
    </div>
    <div class="tool-hero-text">
      <p class="tool-hero-desc"><%= tool.seo_meta_desc %></p>
    </div>
    <div class="tool-hero-badges">
      <span class="hero-badge">100% Free</span>
      <span class="hero-badge">Privacy Safe</span>
      <span class="hero-badge">Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 720px; margin: 0 auto;">

    <!-- STEP 1: UPLOAD -->
    <div class="cv-step" id="step-1-section">
      <div class="cv-step-num"><span>1</span></div>
      <div class="cv-step-body">
        <h3 class="cv-step-title">Open Audio File</h3>

        <!-- Drop Zone -->
        <div class="cv-dropzone" id="drop-zone">
          <input type="file" id="audio-file-input" style="display:none;" accept="audio/*">
          <div class="cv-dropzone-icon">
            <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
          </div>
          <div class="cv-dropzone-text">
            <strong>Drop your audio file here or click to browse</strong>
            <span>Supports MP3, WAV, OGG, FLAC, M4A, etc.</span>
          </div>
          <div class="cv-dropzone-btn">Choose File</div>
        </div>
      </div>
    </div>

    <!-- STEP 2: LOOPER WORKSPACE (hidden initially) -->
    <div class="cv-step hidden" id="step-2-section">
      <div class="cv-step-num"><span>2</span></div>
      <div class="cv-step-body">
        <h3 class="cv-step-title">Configure Loop Intervals</h3>

        <div class="tool-panel" style="padding: 1.75rem; margin-top: 1rem;">
          <div style="font-size:0.9rem; color:var(--text-muted); margin-bottom:1.5rem; display:flex; justify-content:space-between; align-items:center;">
            <span>File: <strong id="info-file-name" style="color:var(--text-primary);">track.mp3</strong></span>
            <span class="badge" id="info-file-duration" style="font-family:var(--font-mono); background:rgba(0,0,0,0.15); padding:0.2rem 0.5rem; border-radius:4px;">00:00</span>
          </div>

          <!-- Waveform Visualizer -->
          <div style="position:relative; height:120px; background:rgba(0,0,0,0.2); border-radius:8px; border:1px solid var(--card-border); margin-bottom:1.5rem; overflow:hidden;">
            <canvas id="looper-canvas" height="120" style="width:100%; height:100%; display:block;"></canvas>
            <div id="looper-progress" style="position:absolute; top:0; left:0; width:0%; height:100%; background:rgba(0,242,254,0.06); pointer-events:none;"></div>
            
            <!-- Shaders overlay representing Loop Start & End bounds -->
            <div id="looper-shade-left" style="position:absolute; top:0; bottom:0; left:0; width:0%; background:rgba(0,0,0,0.4); pointer-events:none;"></div>
            <div id="looper-shade-right" style="position:absolute; top:0; bottom:0; left:100%; right:0; background:rgba(0,0,0,0.4); pointer-events:none;"></div>
          </div>

          <!-- Audio Playback Controls -->
          <div style="display:flex; justify-content:center; align-items:center; gap:1.25rem; margin-bottom:2rem; background:rgba(255,255,255,0.01); border:1px solid rgba(255,255,255,0.03); padding:0.75rem 1.5rem; border-radius:8px;">
            <button class="player-play-btn" id="btn-play-pause" title="Play / Pause">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" id="play-icon"><path d="M8 5v14l11-7z" /></svg>
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" id="pause-icon" class="hidden"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" /></svg>
            </button>
            <div style="font-family:var(--font-mono); font-size:1.1rem; letter-spacing:1px;">
              <span id="player-current-time">00:00</span>
              <span style="color:var(--text-muted); margin:0 0.25rem;">/</span>
              <span id="player-total-time">00:00</span>
            </div>
          </div>

          <!-- Loop Start Slider -->
          <div class="ctrl-group" style="margin-bottom:1.5rem;">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;">
              <span>Loop Start</span>
              <span style="font-family:var(--font-mono); color:var(--accent-primary); font-weight:600;"><span id="val-loop-start">0.00</span>s</span>
            </label>
            <input type="range" id="loop-start" class="styled-slider" min="0" max="100" step="0.05" value="0" style="width:100%;">
          </div>

          <!-- Loop End Slider -->
          <div class="ctrl-group" style="margin-bottom:1.5rem;">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;">
              <span>Loop End</span>
              <span style="font-family:var(--font-mono); color:var(--accent-primary); font-weight:600;"><span id="val-loop-end">0.00</span>s</span>
            </label>
            <input type="range" id="loop-end" class="styled-slider" min="0" max="100" step="0.05" value="0" style="width:100%;">
          </div>

          <!-- Loop Count (repetitions) -->
          <div class="ctrl-group" style="margin-bottom:1.5rem;">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;">
              <span>Loop Count</span>
              <span style="color:var(--text-muted); font-size:0.75rem;">Number of times to repeat the loop (1-100)</span>
            </label>
            <div style="display:flex; align-items:center; gap:1rem;">
              <input type="range" id="loop-count" class="styled-slider" min="1" max="100" step="1" value="4" style="flex:1;">
              <input type="number" id="num-loop-count" class="styled-input" min="1" max="100" value="4" style="width:70px; text-align:center;">
            </div>
          </div>

          <!-- Crossfade (ms) -->
          <div class="ctrl-group" style="margin-bottom:2rem;">
            <label class="ctrl-label" style="display:flex; justify-content:space-between;">
              <span>Crossfade</span>
              <span style="font-family:var(--font-mono); color:var(--accent-primary); font-weight:600;"><span id="val-crossfade">50</span> ms</span>
            </label>
            <input type="range" id="loop-crossfade" class="styled-slider" min="0" max="1000" step="10" value="50" style="width:100%;">
            <p style="font-size:0.75rem; color:var(--text-muted); margin-top:0.4rem;">Smooth transitions between loop repetitions to eliminate clicking or pops at the boundary points.</p>
          </div>

          <!-- Metadata info displays -->
          <div style="display:grid; grid-template-columns: 1fr 1fr; gap:1rem; background:rgba(0,0,0,0.15); padding:1rem; border-radius:8px; margin-bottom:2rem; font-size:0.85rem;" class="split-pane">
            <div style="display:flex; flex-direction:column; gap:0.25rem;">
              <span style="color:var(--text-muted);">Loop Duration:</span>
              <strong id="lbl-loop-duration" style="font-size:1rem; color:var(--text-primary); font-family:var(--font-mono);">0.00s</strong>
            </div>
            <div style="display:flex; flex-direction:column; gap:0.25rem;">
              <span style="color:var(--text-muted);">Total Output:</span>
              <strong id="lbl-total-duration" style="font-size:1rem; color:var(--accent-primary); font-family:var(--font-mono);">0.00s</strong>
            </div>
          </div>

          <!-- Actions -->
          <div style="display:flex; justify-content:flex-end; gap:1rem; border-top:1px solid rgba(255,255,255,0.05); padding-top:1.5rem;">
            <button class="btn btn-secondary" id="btn-reset">Reset</button>
            <button class="btn btn-primary" id="btn-loop" style="background:var(--accent-gradient); min-width:180px;">Create Loop & Download</button>
          </div>
        </div>
      </div>
    </div>

    <!-- STEP 3: PROCESSING -->
    <div class="panel-progress hidden" id="processing-card" style="margin-top: 2rem;">
      <div class="progress-status" id="processing-status">Synthesizing looped audio...</div>
      <div class="progress-track">
        <div class="progress-bar" id="processing-progress-bar" style="width:10%;"></div>
      </div>
    </div>

    <!-- STEP 4: SUCCESS DOWNLOAD -->
    <div class="panel-download hidden" id="download-card" style="margin-top: 2rem; padding: 2rem;">
      <div class="download-icon" style="background:rgba(16,185,129,0.1); color:var(--success); border-color:rgba(16,185,129,0.2);">
        <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
      </div>
      <div class="download-info">
        <strong>Audio Looped Successfully!</strong>
        <span id="download-file-size" style="font-family:var(--font-mono); color:var(--success);">0.00 MB</span>
      </div>
      <div style="display:flex; gap:1rem; margin-top:1.5rem; width:100%; justify-content:center;">
        <button class="btn btn-secondary" id="btn-loop-another">Loop Another</button>
        <a href="" id="download-link" download class="btn btn-success" style="background:var(--success); color:white; text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem; font-weight:600; padding: 0.75rem 1.5rem;">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Download Loop
        </a>
      </div>
    </div>

  </div>
</div>
