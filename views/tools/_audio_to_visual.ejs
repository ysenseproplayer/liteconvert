<!-- Add Audio to Image / Audio to GIF Tool -->
<%
  const isGif = tool.tool_key === 'audio-to-gif';
  const outputLabel = isGif ? 'GIF' : 'Image with Audio';
  const inputAccept = isGif ? '.gif,image/gif' : '.jpg,.jpeg,.png,image/jpeg,image/png';
  const inputLabel = isGif ? 'GIF' : 'Image (JPG/PNG)';
%>

<div class="audio-workbench" data-tool-key="<%= tool.tool_key %>" data-tool-category="<%= tool.category %>">
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
    </div>
    <div class="tool-hero-text"><p class="tool-hero-desc"><%= tool.intro_paragraph || tool.page_description %></p></div>
    <div class="tool-hero-badges">
      <span class="hero-badge">100% Free</span>
      <span class="hero-badge">Privacy Safe</span>
      <span class="hero-badge">Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 700px; margin: 0 auto;">

    <!-- How it works note -->
    <div style="background: rgba(0,242,254,0.04); border: 1px solid rgba(0,242,254,0.12); border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1.5rem; font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5;">
      <strong style="color: var(--accent-primary);">How it works:</strong> Upload an audio file and a <%= inputLabel %>.
      We'll create a downloadable video file (MP4/WebM) that combines both as an audio-visual track, since browsers cannot embed audio directly inside image files. This works perfectly for social media and messaging apps.
    </div>

    <!-- Two-column upload -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">

      <!-- Audio Upload -->
      <div class="tool-panel">
        <div class="panel-label">Step 1 — Upload Audio</div>
        <div id="ati-audio-drop" class="cv-dropzone" style="margin-top: 0.75rem; min-height: 100px;">
          <input type="file" id="ati-audio-input" style="display:none;" accept="audio/*,.mp3,.wav,.ogg">
          <div class="cv-dropzone-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg></div>
          <div class="cv-dropzone-text"><strong>Drop audio here</strong><span>MP3, WAV, OGG</span></div>
        </div>
        <div id="ati-audio-info" class="hidden" style="margin-top: 0.5rem; font-size: 0.82rem; color: var(--text-secondary); word-break: break-all;"></div>
      </div>

      <!-- Image/GIF Upload -->
      <div class="tool-panel">
        <div class="panel-label">Step 2 — Upload <%= inputLabel %></div>
        <div id="ati-img-drop" class="cv-dropzone" style="margin-top: 0.75rem; min-height: 100px;">
          <input type="file" id="ati-img-input" style="display:none;" accept="<%= inputAccept %>">
          <div class="cv-dropzone-icon"><svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>
          <div class="cv-dropzone-text"><strong>Drop <%= inputLabel %> here</strong><span>or click to browse</span></div>
        </div>
        <div id="ati-img-preview-wrap" class="hidden" style="margin-top: 0.5rem; text-align: center;">
          <img id="ati-img-preview" src="" alt="Preview" style="max-width: 100%; max-height: 100px; border-radius: 8px; border: 1px solid var(--card-border); object-fit: cover;">
        </div>
      </div>
    </div>

    <!-- Combine Button -->
    <button id="ati-btn-combine" class="btn-main-action" style="width: 100%; margin-bottom: 1.5rem;" disabled>
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      Combine Audio + <%= inputLabel %>
    </button>

    <!-- Processing -->
    <div id="ati-processing-card" class="tool-panel hidden" style="text-align: center; padding: 2rem; margin-bottom: 1.5rem;">
      <div id="ati-status" style="font-size: 1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 1rem;">Combining files...</div>
      <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
        <div id="ati-progress" style="width: 30%; height: 100%; background: var(--accent-gradient); border-radius: 3px; animation: progress-slide 2s ease infinite alternate;"></div>
      </div>
    </div>
    <style>
    @keyframes progress-slide { from { width: 20%; } to { width: 90%; } }
    </style>

    <!-- Result -->
    <div id="ati-result-card" class="tool-panel hidden" style="text-align: center; padding: 2rem; border: 1px solid rgba(16,185,129,0.2); background: rgba(16,185,129,0.02);">
      <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--success); margin: 0 auto 1rem; display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <h3 style="font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Files Combined!</h3>
      <p id="ati-output-info" style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">Your audio-visual file is ready to download.</p>
      <video id="ati-preview-player" controls style="max-width: 100%; border-radius: 12px; border: 1px solid var(--card-border); margin-bottom: 1.5rem; background: #000; display: none;"></video>
      <br>
      <a id="ati-download-link" href="" download class="btn btn-success" style="background: var(--success); color: white; padding: 0.75rem 2rem; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 600;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download Video File
      </a>
    </div>

  </div>
</div>


