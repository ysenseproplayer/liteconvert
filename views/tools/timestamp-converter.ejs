<div class="grid-layout">
  <div class="card">
    <h3>Unix Timestamp to Date</h3>
    <div class="settings-group"><label for="time-unix">Unix Epoch Timestamp</label><input type="text" id="time-unix" class="styled-input mono" placeholder="e.g. 1782396634"></div>
    <div class="settings-group" style="margin-top:1rem;"><label>Readable GMT Calendar Date</label><input type="text" id="time-date-gmt" class="styled-input" readonly></div>
    <div class="settings-group"><label>Local Date Time</label><input type="text" id="time-date-local" class="styled-input" readonly></div>
  </div>
  <div class="card">
    <h3>Date to Unix Timestamp</h3>
    <div class="settings-group"><label for="time-year">Year</label><input type="number" id="time-year" class="styled-input" value="2026"></div>
    <div class="settings-row">
      <div class="settings-group"><label for="time-month">Month (1-12)</label><input type="number" id="time-month" class="styled-input" value="6" min="1" max="12"></div>
      <div class="settings-group"><label for="time-day">Day (1-31)</label><input type="number" id="time-day" class="styled-input" value="25" min="1" max="31"></div>
    </div>
    <button class="btn btn-primary btn-full mt-lg" id="btn-date-to-unix">Convert to Epoch</button>
    <div class="settings-group" style="margin-top:1rem;"><label>Epoch Result (seconds)</label><input type="text" id="time-unix-output" class="styled-input mono" readonly></div>
  </div>
</div>
