<div class="grid-layout">
  <div class="card">
    <h3>Configure .htaccess Parameters</h3>
    <div style="display: flex; flex-direction: column; gap: 1.25rem; margin-top: 1rem;">
      <label class="checkbox-container">
        <input type="checkbox" id="rule-https">
        <span class="checkmark"></span>
        Redirect HTTP to HTTPS (Secure SSL)
      </label>
      <label class="checkbox-container">
        <input type="checkbox" id="rule-www">
        <span class="checkmark"></span>
        Redirect non-WWW to WWW URL
      </label>
      <label class="checkbox-container">
        <input type="checkbox" id="rule-indexes" checked>
        <span class="checkmark"></span>
        Disable Directory Listing (Options -Indexes)
      </label>
      <div class="settings-group">
        <label for="rule-hotlink">Prevent Hotlinking for (comma-separated domains)</label>
        <input type="text" id="rule-hotlink" class="styled-input" placeholder="e.g. mydomain.com">
      </div>
    </div>
  </div>

  <div class="card pane-card">
    <div class="pane-header">
      <span>Generated Code</span>
      <button class="text-btn success" id="btn-copy-htaccess">Copy</button>
    </div>
    <textarea id="htaccess-output" class="pane-textarea mono" readonly style="min-height: 250px;"></textarea>
  </div>
</div>
