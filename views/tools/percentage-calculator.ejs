<div class="grid-layout">
  <div class="card">
    <h3>Calculate Percentage of Value</h3>
    <div style="display:flex; align-items:center; gap:0.5rem; margin-top:1rem;">
      <span>What is</span><input type="number" id="perc-val-1" class="styled-input" style="width:100px;" value="15">
      <span>% of</span><input type="number" id="perc-val-2" class="styled-input" style="width:150px;" value="200">
      <span>?</span>
    </div>
    <div class="settings-group" style="margin-top:1.5rem;"><label>Calculated Answer</label><input type="text" id="perc-ans-1" class="styled-input" readonly></div>
  </div>
  <div class="card">
    <h3>Calculate Percentage Increase / Decrease</h3>
    <div style="display:flex; align-items:center; gap:0.5rem; margin-top:1rem;">
      <span>From</span><input type="number" id="perc-inc-1" class="styled-input" style="width:120px;" value="100">
      <span>to</span><input type="number" id="perc-inc-2" class="styled-input" style="width:120px;" value="125">
      <span>?</span>
    </div>
    <div class="settings-group" style="margin-top:1.5rem;"><label>Calculated Difference Answer</label><input type="text" id="perc-ans-2" class="styled-input" readonly></div>
  </div>
</div>
