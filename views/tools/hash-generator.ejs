<div class="card pane-card">
  <div class="pane-header"><span>Enter Raw String</span></div>
  <textarea id="hash-input" class="pane-textarea" placeholder="Enter string here..." style="min-height:100px;"></textarea>
</div>
<div class="card" style="margin-top:1.5rem; display:flex; flex-direction:column; gap:1.25rem;">
  <div class="settings-group">
    <label>MD5 Hash</label>
    <div style="display:flex; gap:0.5rem;"><input type="text" id="hash-md5" class="styled-input mono" readonly><button class="btn btn-secondary" id="btn-copy-md5">Copy</button></div>
  </div>
  <div class="settings-group">
    <label>SHA-256 Hash</label>
    <div style="display:flex; gap:0.5rem;"><input type="text" id="hash-sha256" class="styled-input mono" readonly><button class="btn btn-secondary" id="btn-copy-sha256">Copy</button></div>
  </div>
</div>
