<div class="audio-workbench" data-tool-key="<%= tool.tool_key %>" data-tool-category="<%= tool.category %>">

  <!-- TOOL HERO HEADER -->
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 100-6 3 3 0 000 6z" />
      </svg>
    </div>
    <div class="tool-hero-text">
      <p class="tool-hero-desc"><%= tool.intro_paragraph || tool.page_description %></p>
    </div>
    <div class="tool-hero-badges">
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg> 100% Free</span>
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg> Privacy Safe</span>
      <span class="hero-badge"><svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg> Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 680px; margin: 0 auto;">

    <!-- UPLOAD -->
    <div class="tool-panel" id="brc-upload-card" style="margin-bottom: 1.5rem;">
      <div class="panel-label">Upload MP3 Audio</div>
      <div class="cv-dropzone" id="brc-drop-zone" style="margin-top: 0.75rem;">
        <input type="file" id="brc-file-input" style="display:none;" accept="audio/*,video/*">
        <div class="cv-dropzone-icon">
          <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
        </div>
        <div class="cv-dropzone-text">
          <strong>Drag & drop audio here, or click to upload</strong>
          <span>Supports MP3, WAV, M4A, FLAC, OGG, AAC and more</span>
        </div>
        <div class="cv-dropzone-btn">Choose File</div>
      </div>
    </div>

    <!-- MAIN EDITOR (hidden after upload) -->
    <div class="tool-panel hidden" id="brc-editor-card" style="margin-bottom: 1.5rem; padding: 1.5rem; background: rgba(25, 20, 15, 0.4); border: 1px solid rgba(249, 115, 22, 0.15);">
      
      <!-- Top info bar with reset -->
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
        <div style="display: flex; gap: 0.5rem; align-items: center; color: var(--text-primary);">
          <span style="font-size: 1.1rem; color: #f97316;">🎵</span>
          <div>
            <div id="brc-file-name" style="font-weight: 600; font-size: 0.95rem; word-break: break-all;">SPIDER-MAN.mp3</div>
            <div style="font-size: 0.78rem; color: var(--text-muted);">
              Source: <span id="brc-source-format">MP3</span> · <span id="brc-source-duration">0:00</span> · ~<span id="brc-source-bitrate">192</span> kbps
            </div>
          </div>
        </div>
        <button id="brc-btn-reset" style="background: transparent; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.85rem; display: flex; align-items: center; gap: 0.35rem; transition: color 0.2s;" onmouseover="this.style.color='var(--danger)'" onmouseout="this.style.color='var(--text-muted)'">
          ✕ New file
        </button>
      </div>

      <!-- Waveform (Orange colored style) -->
      <div style="background: rgba(0,0,0,0.25); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; padding: 0.75rem; margin-bottom: 1.5rem;">
        <canvas id="brc-waveform-canvas" height="84" style="width: 100%; height: 84px; display: block;"></canvas>
      </div>

      <!-- Pick a Bitrate Pill Group -->
      <div style="margin-bottom: 1.25rem;">
        <div class="ctrl-label" style="margin-bottom: 0.75rem; color: var(--text-secondary); font-size: 0.85rem;">Pick a bitrate</div>
        <div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.5rem;" id="brc-pill-container">
          <button class="cv-pill-large" data-bitrate="64">
            <strong>64 kbps</strong>
            <span>voice only</span>
          </button>
          <button class="cv-pill-large" data-bitrate="128">
            <strong>128 kbps</strong>
            <span>small</span>
          </button>
          <button class="cv-pill-large active" data-bitrate="192">
            <strong>192 kbps</strong>
            <span>standard</span>
          </button>
          <button class="cv-pill-large" data-bitrate="256">
            <strong>256 kbps</strong>
            <span>high</span>
          </button>
          <button class="cv-pill-large" data-bitrate="320">
            <strong>320 kbps</strong>
            <span>max</span>
          </button>
        </div>
      </div>

      <!-- Size readout -->
      <div style="text-align: center; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 1.25rem;">
        Estimated new size: <strong style="color: var(--text-primary);" id="brc-est-size">— MB</strong> 
        (source ~<span id="brc-src-size-val">— MB</span> → <span id="brc-dest-size-val">— MB</span>)
      </div>

      <!-- Re-encoding lossy warning -->
      <div style="display: flex; gap: 0.75rem; background: rgba(249, 115, 22, 0.05); border: 1px solid rgba(249, 115, 22, 0.15); border-radius: 8px; padding: 0.75rem; font-size: 0.8rem; line-height: 1.4; color: var(--text-secondary); margin-bottom: 1.5rem;">
        <span style="color: #f97316; font-size: 1.1rem; flex-shrink: 0; line-height: 1;">ℹ</span>
        <div>
          <strong style="color: var(--text-primary);">Re-encoding is lossy.</strong> MP3 is a lossy format, so every re-encode introduces a bit of quality loss. For lossless sources (WAV, FLAC) this is expected. For MP3 → MP3, avoid going lower unless you need smaller files.
        </div>
      </div>

      <!-- Main Action Trigger -->
      <button id="brc-btn-process" class="btn-main-action" style="width: 100%; padding: 0.9rem; font-weight: 700; background: var(--accent-gradient); border-color: transparent;">
        ⚡ Change Bitrate & Download
      </button>

      <!-- Sub text status -->
      <div id="brc-status-info" style="text-align: center; margin-top: 0.75rem; font-size: 0.78rem; color: var(--text-muted);">
        100% in your browser — nothing uploaded. Output is an MP3 at 192 kbps.
      </div>
    </div>

    <!-- Inline stylesheet to customize the pill buttons -->
    <style>
      .cv-pill-large {
        background: rgba(255,255,255,0.02);
        border: 1px solid var(--card-border);
        border-radius: 8px;
        padding: 0.65rem 0.25rem;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        align-items: center;
        transition: all 0.2s;
        text-align: center;
        color: var(--text-secondary);
      }
      .cv-pill-large strong {
        font-size: 0.85rem;
        color: var(--text-primary);
        font-family: var(--font-heading);
      }
      .cv-pill-large span {
        font-size: 0.68rem;
        color: var(--text-muted);
        margin-top: 0.15rem;
      }
      .cv-pill-large:hover {
        background: rgba(249, 115, 22, 0.04);
        border-color: rgba(249, 115, 22, 0.3);
      }
      .cv-pill-large.active {
        background: #f97316 !important;
        border-color: #ea580c !important;
      }
      .cv-pill-large.active strong {
        color: white !important;
      }
      .cv-pill-large.active span {
        color: rgba(255, 255, 255, 0.8) !important;
      }
      @media (max-width: 560px) {
        #brc-pill-container { grid-template-columns: repeat(3, 1fr) !important; }
      }
    </style>

    <!-- PROGRESS -->
    <div class="tool-panel hidden" id="brc-progress-card" style="text-align: center; padding: 2rem; margin-bottom: 1.5rem;">
      <div id="brc-progress-status" style="font-size: 1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 1rem;">Adjusting bitrate...</div>
      <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
        <div id="brc-progress-bar" style="width: 0%; height: 100%; background: var(--accent-gradient); border-radius: 3px; transition: width 0.3s;"></div>
      </div>
    </div>

    <!-- DOWNLOAD CARD -->
    <div class="tool-panel hidden" id="brc-download-card" style="text-align: center; padding: 2.2rem; border: 1px solid rgba(249, 115, 22, 0.3); background: rgba(249, 115, 22, 0.02);">
      <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#f97316; margin: 0 auto 1rem; display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Process Complete!</h3>
      <p id="brc-download-info" style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">—</p>
      <a id="brc-download-link" href="" download class="btn-download" style="display: inline-flex; background: #f97316; border-color: #ea580c; color: white;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download File
      </a>
      <br>
      <button id="brc-btn-another" class="ctrl-btn-mini" style="margin-top: 1rem;">Process Another File</button>
    </div>

  </div>
</div>
