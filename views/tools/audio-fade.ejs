<div class="audio-workbench" data-tool-key="<%= tool.tool_key %>" data-tool-category="<%= tool.category %>">

  <!-- TOOL HERO HEADER -->
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
      </svg>
    </div>
    <div class="tool-hero-text">
      <p class="tool-hero-desc"><%= tool.intro_paragraph || tool.page_description %></p>
    </div>
    <div class="tool-hero-badges">
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg> 100% Free</span>
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg> Privacy Safe</span>
      <span class="hero-badge"><svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg> Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 720px; margin: 0 auto;">

    <!-- STEP 1: UPLOAD -->
    <div class="tool-panel" style="margin-bottom: 1.5rem;" id="fade-upload-card">
      <div class="panel-label">Upload Audio File</div>
      <div class="cv-dropzone" id="fade-drop-zone" style="margin-top: 0.75rem;">
        <input type="file" id="fade-file-input" style="display:none;" accept="audio/*,video/*">
        <div class="cv-dropzone-icon">
          <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
        </div>
        <div class="cv-dropzone-text">
          <strong>Drag & drop audio here, or click to upload</strong>
          <span>Supports MP3, WAV, M4A, FLAC, OGG, AAC, and more</span>
        </div>
        <div class="cv-dropzone-btn">Choose File</div>
      </div>
    </div>

    <!-- FILE INFO (shown after upload) -->
    <div class="tool-panel hidden" id="fade-file-info" style="margin-bottom: 1.5rem;">
      <div class="panel-label">File Information</div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-top: 0.75rem; padding: 1rem; background: rgba(0,0,0,0.15); border: 1px solid var(--card-border); border-radius: 8px;">
        <div>
          <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Filename</div>
          <div id="fade-info-name" style="font-weight: 600; font-size: 0.9rem; color: var(--text-primary); word-break: break-all;">—</div>
        </div>
        <div>
          <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Size</div>
          <div id="fade-info-size" style="font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">—</div>
        </div>
        <div>
          <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Duration</div>
          <div id="fade-info-duration" style="font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">—</div>
        </div>
        <div>
          <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Sample Rate</div>
          <div id="fade-info-srate" style="font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">—</div>
        </div>
      </div>
      <button id="fade-btn-new-file" class="ctrl-btn-mini" style="margin-top: 0.75rem;">
        <svg width="10" height="10" fill="currentColor" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        <span>New File</span>
      </button>
    </div>

    <!-- PREVIEW + SETTINGS GRID -->
    <div class="hidden" id="fade-controls-area" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">

      <!-- Original Preview -->
      <div class="tool-panel" style="margin-bottom: 0;">
        <div class="panel-label">Original Preview</div>
        <div style="margin-top: 0.75rem;">
          <div style="background: rgba(0,0,0,0.2); border: 1px solid var(--card-border); border-radius: 8px; padding: 0.75rem; position: relative;">
            <canvas id="fade-waveform-canvas" height="80" style="width:100%; height:80px; display:block;"></canvas>
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.75rem;">
            <button id="fade-btn-play" class="player-play-btn" title="Play">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" id="fade-play-icon"><path d="M8 5v14l11-7z" /></svg>
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24" id="fade-pause-icon" class="hidden"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" /></svg>
            </button>
            <button id="fade-btn-stop" class="ctrl-btn-mini" title="Stop">
              <svg width="10" height="10" fill="currentColor" viewBox="0 0 24 24"><path d="M6 6h12v12H6z" /></svg>
              <span>Stop</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Fade Settings -->
      <div class="tool-panel" style="margin-bottom: 0;">
        <div class="panel-label">Fade Settings</div>
        <div style="margin-top: 0.75rem; display: flex; flex-direction: column; gap: 1.25rem;">

          <!-- Fade In -->
          <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
              <span class="ctrl-label" style="margin: 0;">Fade in duration</span>
              <span id="fade-in-val" style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent-primary);">0.5s</span>
            </div>
            <input type="range" id="fade-in-slider" class="styled-slider" min="0" max="30" step="0.5" value="0.5" style="width: 100%;">
            <div style="display: flex; gap: 0.4rem; margin-top: 0.5rem; flex-wrap: wrap;">
              <button class="cv-pill fade-preset-in" data-val="0">0s</button>
              <button class="cv-pill active fade-preset-in" data-val="0.5">0.5s</button>
              <button class="cv-pill fade-preset-in" data-val="1">1s</button>
              <button class="cv-pill fade-preset-in" data-val="2">2s</button>
              <button class="cv-pill fade-preset-in" data-val="5">5s</button>
              <button class="cv-pill fade-preset-in" data-val="10">10s</button>
            </div>
          </div>

          <!-- Fade Out -->
          <div>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
              <span class="ctrl-label" style="margin: 0;">Fade out duration</span>
              <span id="fade-out-val" style="font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent-primary);">0.5s</span>
            </div>
            <input type="range" id="fade-out-slider" class="styled-slider" min="0" max="30" step="0.5" value="0.5" style="width: 100%;">
            <div style="display: flex; gap: 0.4rem; margin-top: 0.5rem; flex-wrap: wrap;">
              <button class="cv-pill fade-preset-out" data-val="0">0s</button>
              <button class="cv-pill active fade-preset-out" data-val="0.5">0.5s</button>
              <button class="cv-pill fade-preset-out" data-val="1">1s</button>
              <button class="cv-pill fade-preset-out" data-val="2">2s</button>
              <button class="cv-pill fade-preset-out" data-val="5">5s</button>
              <button class="cv-pill fade-preset-out" data-val="10">10s</button>
            </div>
          </div>

          <!-- Export Format -->
          <div>
            <span class="ctrl-label">Export format</span>
            <div style="display: flex; gap: 0.5rem; margin-top: 0.35rem;">
              <select id="fade-export-format" class="styled-select" style="max-width: 140px;">
                <option value="wav">WAV</option>
                <option value="mp3">MP3</option>
              </select>
              <span style="font-size: 0.78rem; color: var(--text-muted); display: flex; align-items: center;">The export will have the 0.5s in and fade out over the last 0.5s.</span>
            </div>
          </div>

          <!-- Tips -->
          <div style="background: rgba(0,0,0,0.12); border: 1px solid var(--card-border); border-radius: 8px; padding: 0.75rem; font-size: 0.8rem; color: var(--text-secondary); line-height: 1.5;">
            <p style="margin: 0 0 0.5rem 0;">Use moderate, short fades; lighter, while longer fades sound softer and more cinematic.</p>
            <p style="margin: 0; color: var(--warning); border-top: 1px solid rgba(255,255,255,0.05); padding-top: 0.5rem;">⚠ Keep the combined fade lengths shorter than the full clip duration. Extremely long fades can make short clips flat sounding.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- RESPONSIVE OVERRIDE -->
    <style>
      @media (max-width: 768px) {
        #fade-controls-area { grid-template-columns: 1fr !important; }
      }
    </style>

    <!-- ACTION BUTTON -->
    <div class="hidden" id="fade-action-area" style="margin-bottom: 1.5rem;">
      <button id="fade-btn-process" class="btn-main-action" style="width: 100%;">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        Apply Fades
      </button>
    </div>

    <!-- PROGRESS -->
    <div class="tool-panel hidden" id="fade-progress-card" style="text-align: center; padding: 2rem; margin-bottom: 1.5rem;">
      <div id="fade-progress-status" style="font-size: 1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 1rem;">Applying fades...</div>
      <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
        <div id="fade-progress-bar" style="width: 0%; height: 100%; background: var(--accent-gradient); border-radius: 3px; transition: width 0.3s;"></div>
      </div>
    </div>

    <!-- DOWNLOAD -->
    <div class="tool-panel hidden" id="fade-download-card" style="text-align: center; padding: 2rem; border: 1px solid rgba(16,185,129,0.2); background: rgba(16,185,129,0.02);">
      <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--success); margin: 0 auto 1rem; display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <h3 style="font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Fades Applied Successfully!</h3>
      <p id="fade-download-info" style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">—</p>
      <a id="fade-download-link" href="" download class="btn-download" style="display: inline-flex;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download File
      </a>
      <br>
      <button id="fade-btn-another" class="ctrl-btn-mini" style="margin-top: 1rem;">Process Another File</button>
    </div>

  </div>
</div>
