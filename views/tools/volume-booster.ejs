<div class="audio-workbench" data-tool-key="<%= tool.tool_key %>" data-tool-category="<%= tool.category %>">

  <!-- TOOL HERO HEADER -->
  <div class="tool-hero">
    <div class="tool-hero-icon">
      <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.536 8.464a5 5 0 010 7.072M18.364 5.636a9 9 0 010 12.728M11 5L6 9H2v6h4l5 4V5z" />
      </svg>
    </div>
    <div class="tool-hero-text">
      <p class="tool-hero-desc"><%= tool.intro_paragraph || tool.page_description %></p>
    </div>
    <div class="tool-hero-badges">
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg> 100% Free</span>
      <span class="hero-badge"><svg width="12" height="12" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" /></svg> Privacy Safe</span>
      <span class="hero-badge"><svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg> Browser-Side</span>
    </div>
  </div>

  <div style="max-width: 800px; margin: 0 auto;">

    <!-- UPLOAD -->
    <div class="tool-panel" id="vol-upload-card" style="margin-bottom: 1.5rem;">
      <div class="panel-label">Upload Audio File</div>
      <div class="cv-dropzone" id="vol-drop-zone" style="margin-top: 0.75rem;">
        <input type="file" id="vol-file-input" style="display:none;" accept="audio/*,video/*">
        <div class="cv-dropzone-icon">
          <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" /></svg>
        </div>
        <div class="cv-dropzone-text">
          <strong>Drag & drop audio here, or click to upload</strong>
          <span>Supports MP3, WAV, M4A, FLAC, OGG, AAC, and more</span>
        </div>
        <div class="cv-dropzone-btn">Choose File</div>
      </div>
    </div>

    <!-- WAVEFORM + CONTROLS (shown after upload) -->
    <div class="hidden" id="vol-editor-area">

      <!-- File name bar -->
      <div style="text-align: center; margin-bottom: 0.75rem;">
        <span id="vol-file-name" style="color: var(--accent-primary); font-weight: 600; font-size: 0.9rem;"></span>
      </div>

      <!-- Waveform -->
      <div class="tool-panel" style="margin-bottom: 1.25rem; padding: 0; overflow: hidden; background: rgba(10,15,30,0.95); border: 1px solid var(--card-border);">
        <div style="padding: 1rem; position: relative;">
          <canvas id="vol-waveform-canvas" height="140" style="width:100%; height:140px; display:block;"></canvas>
          <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-muted); margin-top: 0.4rem; font-family: var(--font-mono);">
            <span id="vol-time-start">00:00.0</span>
            <span id="vol-time-duration">00:00</span>
            <span id="vol-time-end">00:00.0</span>
          </div>
        </div>
      </div>

      <!-- Player Controls -->
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
        <button id="vol-btn-play" class="player-play-btn" title="Play" style="width: 44px; height: 44px;">
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" id="vol-play-icon"><path d="M8 5v14l11-7z" /></svg>
          <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" id="vol-pause-icon" class="hidden"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z" /></svg>
        </button>

        <!-- Volume Slider -->
        <div style="flex: 1; display: flex; align-items: center; gap: 0.75rem;">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color: var(--text-muted); flex-shrink: 0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M11 5L6 9H2v6h4l5 4V5z" /></svg>
          <input type="range" id="vol-gain-slider" class="styled-slider" min="0" max="500" step="5" value="100" style="flex: 1;">
          <span id="vol-gain-val" style="font-family: var(--font-mono); font-size: 0.9rem; color: var(--accent-primary); min-width: 50px; text-align: right; font-weight: 600;">0</span>
        </div>

        <!-- Format + Save -->
        <div style="display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0;">
          <select id="vol-format" class="styled-select" style="width: 80px;">
            <option value="mp3">mp3</option>
            <option value="wav">wav</option>
          </select>
          <button id="vol-btn-save" class="btn-main-action" style="padding: 0.65rem 1.5rem; white-space: nowrap;">
            Save
          </button>
        </div>
      </div>

      <!-- Reset -->
      <div style="display: flex; justify-content: flex-end; margin-bottom: 0.5rem; gap: 0.75rem;">
        <button id="vol-btn-reset" class="ctrl-btn-mini">
          <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          <span>Reset</span>
        </button>
        <button id="vol-btn-new-file" class="ctrl-btn-mini">
          <svg width="10" height="10" fill="currentColor" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
          <span>New File</span>
        </button>
      </div>
    </div>

    <!-- Responsive for mobile -->
    <style>
      @media (max-width: 640px) {
        #vol-editor-area > div:nth-child(3) { flex-wrap: wrap; }
      }
    </style>

    <!-- PROGRESS -->
    <div class="tool-panel hidden" id="vol-progress-card" style="text-align: center; padding: 2rem; margin-bottom: 1.5rem;">
      <div id="vol-progress-status" style="font-size: 1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 1rem;">Boosting volume...</div>
      <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
        <div id="vol-progress-bar" style="width: 0%; height: 100%; background: var(--accent-gradient); border-radius: 3px; transition: width 0.3s;"></div>
      </div>
    </div>

    <!-- DOWNLOAD -->
    <div class="tool-panel hidden" id="vol-download-card" style="text-align: center; padding: 2rem; border: 1px solid rgba(16,185,129,0.2); background: rgba(16,185,129,0.02);">
      <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--success); margin: 0 auto 1rem; display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <h3 style="font-size: 1.2rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.5rem;">Volume Adjusted!</h3>
      <p id="vol-download-info" style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.5rem;">—</p>
      <a id="vol-download-link" href="" download class="btn-download" style="display: inline-flex;">
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
        Download
      </a>
      <br>
      <button id="vol-btn-another" class="ctrl-btn-mini" style="margin-top: 1rem;">Process Another File</button>
    </div>

  </div>
</div>
