<div class="grid-layout">
  <div class="card">
    <h3>Palette Generator</h3>
    <div class="settings-group"><label for="palette-seed">Seed Hex Color</label><input type="text" id="palette-seed" class="styled-input" value="#6366f1" placeholder="#6366f1"></div>
    <div class="settings-group" style="margin-top:1rem;"><label for="palette-harmony">Harmony Rule</label><select id="palette-harmony" class="styled-select"><option value="analogous">Analogous Colors</option><option value="monochrome">Monochromatic Colors</option><option value="triadic">Triadic Colors</option></select></div>
    <button class="btn btn-primary btn-full mt-lg" id="btn-gen-palette">Generate Palette</button>
  </div>
  <div class="card">
    <h3>Generated Color Palette</h3>
    <div id="palette-results-container" style="display:grid; grid-template-columns:repeat(5, 1fr); gap:0.5rem; margin-top:1.5rem;">
      <!-- Populated by JS -->
    </div>
  </div>
</div>
