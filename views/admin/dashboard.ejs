<%- include('../partials/header', { activePage: 'admin' }) %>

<main class="workspace">
  <header class="workspace-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--card-border); padding-bottom: 1.5rem; margin-bottom: 2rem;">
    <div class="title-area">
      <h2 id="tool-title">CMS Admin Control Panel</h2>
      <p id="tool-description" class="subtitle">Logged in as: <strong><%= username %></strong></p>
    </div>
    <div>
      <a href="/admin/logout" class="btn btn-secondary">Logout</a>
    </div>
  </header>

  <div class="workspace-content">
    
    <!-- STATS MODULES -->
    <div class="dashboard-grid">
      <div class="stat-card">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
        </div>
        <div class="stat-info">
          <h4>Total Conversions Log</h4>
          <div class="stat-number" id="stats-total-conversions"><%= totalConversions %></div>
        </div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon-wrapper success">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="stat-info">
          <h4>Active Tools</h4>
          <div class="stat-number" id="stats-active-count"><%= activeCount %> / <%= tools.length %></div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon-wrapper warning">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
        </div>
        <div class="stat-info">
          <h4>Database State</h4>
          <div class="stat-number" style="color: var(--success);">Connected</div>
        </div>
      </div>
    </div>

    <!-- MODULE SETTINGS CMS TABLE -->
    <h3 class="settings-section-title">Module Settings CMS</h3>
    <div class="card admin-card" style="margin-bottom: 2.5rem;">
      <table class="admin-table">
        <thead>
          <tr>
            <th style="width: 25%;">Tool name</th>
            <th style="width: 25%;">Category</th>
            <th style="width: 15%; text-align: center;">Conversions</th>
            <th style="width: 15%; text-align: center;">Status</th>
            <th style="width: 20%; text-align: center;">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% tools.forEach(t => { %>
            <tr data-tool-key="<%= t.tool_key %>">
              <td>
                <span class="bold" style="color: var(--text-primary); font-size: 0.95rem;"><%= t.name %></span><br>
                <span style="font-size: 0.75rem; color: var(--text-muted); font-family: var(--font-mono);"><%= t.tool_key %></span>
              </td>
              <td style="color: var(--text-secondary); font-size: 0.9rem;">
                <%= t.category %>
              </td>
              <td style="text-align: center; font-family: var(--font-mono); font-size: 0.9rem; color: var(--text-secondary);">
                <%= t.use_count %>
              </td>
              <td style="text-align: center; vertical-align: middle;">
                <label class="switch">
                  <input type="checkbox" class="tool-toggle-checkbox" data-tool="<%= t.tool_key %>" <%= t.enabled ? 'checked' : '' %>>
                  <span class="slider-toggle"></span>
                </label>
              </td>
              <td style="text-align: center; vertical-align: middle;">
                <button class="btn btn-secondary btn-edit-tool" data-tool-key="<%= t.tool_key %>" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Edit Settings</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- FAQ CMS SECTION -->
    <h3 class="settings-section-title">FAQ Manager (SEO booster)</h3>
    <div class="grid-layout" style="margin-bottom: 2.5rem;">
      <div class="card" style="max-height: 500px; overflow-y: auto;">
        <h3>Existing FAQs list</h3>
        <div style="display: flex; flex-direction: column; gap: 1rem;" id="faqs-list-container">
          <% faqs.forEach(faq => { %>
            <div class="faq-item-card" data-faq-id="<%= faq.id %>" style="border: 1px solid var(--card-border); border-radius: var(--radius-md); padding: 1rem; background-color: rgba(255,255,255,0.01); display: flex; flex-direction: column; gap: 0.5rem; position: relative;">
              <span style="font-size: 0.7rem; background-color: rgba(99, 102, 241, 0.1); color: var(--accent-primary); border-radius: 4px; padding: 0.15rem 0.4rem; font-weight: 600; width: max-content;">
                <%= faq.tool_name %>
              </span>
              <h4 style="font-size: 0.95rem; font-weight: 600;"><%= faq.question %></h4>
              <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5;"><%= faq.answer %></p>
              <button class="text-btn btn-delete-faq" data-faq-id="<%= faq.id %>" style="color: var(--danger); position: absolute; top: 1rem; right: 1rem;">Delete</button>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="card">
        <h3>Add FAQ</h3>
        <form id="add-faq-form">
          <div class="settings-group">
            <label for="faq-tool-id">Select Tool Module</label>
            <select id="faq-tool-id" class="styled-select" required>
              <% tools.forEach(t => { %>
                <option value="<%= t.id %>"><%= t.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="settings-group">
            <label for="faq-question">Question</label>
            <input type="text" id="faq-question" class="styled-input" placeholder="e.g. Is this tool secure?" required>
          </div>
          <div class="settings-group">
            <label for="faq-answer">Answer</label>
            <textarea id="faq-answer" class="pane-textarea" style="min-height: 100px;" placeholder="FAQ answer text..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-full mt-lg">Add FAQ</button>
        </form>
      </div>
    </div>

    <!-- ADS MANAGEMENT MODULE -->
    <h3 class="settings-section-title">Ads Manager (Monetization Settings)</h3>
    <div class="card admin-card" style="margin-bottom: 2.5rem; padding: 2rem;">
      <p class="card-desc" style="margin-bottom: 1.5rem; color: var(--text-secondary);">Configure ad script slots to embed HTML/JS code blocks (AdSense, Ezoic, etc.) dynamically across the site.</p>
      
      <form id="ads-config-form" style="display: flex; flex-direction: column; gap: 1.25rem;">
        <div class="settings-group">
          <label for="ad-header" style="font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; display: block; font-size: 0.95rem;">Header Ad Script (renders below workspace header)</label>
          <textarea id="ad-header" class="pane-textarea mono" style="min-height: 100px; font-size: 0.85rem;" placeholder="Paste header ad HTML/JS code here..."><%= globalSettings.ad_header || '' %></textarea>
        </div>
        
        <div class="settings-group">
          <label for="ad-sidebar" style="font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; display: block; font-size: 0.95rem;">Sidebar Ad Script (renders inside sidebar navigation menu)</label>
          <textarea id="ad-sidebar" class="pane-textarea mono" style="min-height: 100px; font-size: 0.85rem;" placeholder="Paste sidebar ad HTML/JS code here..."><%= globalSettings.ad_sidebar || '' %></textarea>
        </div>
        
        <div class="settings-group">
          <label for="ad-footer" style="font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; display: block; font-size: 0.95rem;">Footer Ad Script (renders above the footer layout)</label>
          <textarea id="ad-footer" class="pane-textarea mono" style="min-height: 100px; font-size: 0.85rem;" placeholder="Paste footer ad HTML/JS code here..."><%= globalSettings.ad_footer || '' %></textarea>
        </div>
        
        <button type="submit" class="btn btn-primary" style="align-self: flex-start; min-width: 150px;">Save Ads Configuration</button>
      </form>
    </div>

    <!-- DANGER ZONE -->
    <h3 class="settings-section-title">System Actions</h3>
    <div class="card danger-card" style="margin-bottom: 2.5rem;">
      <h3>Danger Zone</h3>
      <p class="card-desc">Irreversible administrative parameters and analytics wipes.</p>
      <div class="danger-row">
        <div class="danger-info">
          <h4>Wipe Conversion Counters</h4>
          <p>Resets all tool conversions counts back to zero.</p>
        </div>
        <button class="btn btn-danger" id="btn-wipe-stats">Wipe Stats Logs</button>
      </div>
    </div>

  </div>
</main>

<!-- Tool Editor Modal -->
<div id="tool-edit-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
  <div class="modal-content card" style="width: 90%; max-width: 800px; max-height: 90vh; overflow-y: auto; padding: 2rem; display: flex; flex-direction: column; gap: 1.5rem; position: relative; border: 1px solid var(--card-border); background-color: #0b0f19;">
    <button id="modal-close" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 1.5rem;">&times;</button>
    <h3 style="margin-top: 0; font-family: var(--font-heading);" id="modal-tool-name">Edit Tool Settings</h3>
    
    <input type="hidden" id="modal-tool-key">

    <!-- SEO Meta Fields -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="settings-group">
        <label for="edit-seo-title">Meta Title</label>
        <input type="text" id="edit-seo-title" class="styled-input" style="width: 100%;">
      </div>
      <div class="settings-group">
        <label for="edit-name">Tool Name (Display)</label>
        <input type="text" id="edit-name" class="styled-input" style="width: 100%;">
      </div>
    </div>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="settings-group">
        <label for="edit-status">Status Mode</label>
        <select id="edit-status" class="styled-select" style="width: 100%;">
          <option value="active">Active Mode (Online)</option>
          <option value="maintenance">Maintenance Mode</option>
          <option value="coming_soon">Coming Soon Mode</option>
          <option value="disabled">Disabled (Restricted)</option>
        </select>
      </div>
      <div class="settings-group">
        <label for="edit-image-path">Image Path / URL</label>
        <input type="text" id="edit-image-path" class="styled-input" style="width: 100%;" placeholder="e.g. /images/tools/mp3-cutter.png">
      </div>
    </div>

    <div class="settings-group">
      <label for="edit-seo-desc">Meta Description</label>
      <textarea id="edit-seo-desc" class="pane-textarea" style="min-height: 60px; font-size: 0.85rem; width: 100%;"></textarea>
    </div>

    <!-- Dual Paragraph Editor -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
      <div class="settings-group">
        <label for="edit-desc-top">Top Paragraph (Intro block)</label>
        <textarea id="edit-desc-top" class="pane-textarea" style="min-height: 100px; font-size: 0.85rem; width: 100%;"></textarea>
      </div>
      <div class="settings-group">
        <label for="edit-desc-bottom">Bottom Paragraph (About section)</label>
        <textarea id="edit-desc-bottom" class="pane-textarea" style="min-height: 100px; font-size: 0.85rem; width: 100%;"></textarea>
      </div>
    </div>

    <!-- Bullet Points -->
    <div class="settings-group">
      <label for="edit-bullet-points">Bullet Points (One bullet point per line)</label>
      <textarea id="edit-bullet-points" class="pane-textarea" style="min-height: 80px; font-size: 0.85rem; width: 100%;" placeholder="Point 1&#10;Point 2&#10;Point 3"></textarea>
    </div>

    <!-- Ad Units Integration -->
    <h4 style="margin: 0.5rem 0 0 0; border-bottom: 1px solid var(--card-border); padding-bottom: 0.5rem; font-family: var(--font-heading);">Ad Integration Codes (HTML/JS)</h4>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem;">
      <div class="settings-group">
        <label for="edit-ad-top">Ad Top Slot</label>
        <textarea id="edit-ad-top" class="pane-textarea mono" style="min-height: 80px; font-size: 0.75rem; font-family: var(--font-mono); width: 100%;" placeholder="Paste ad code here"></textarea>
      </div>
      <div class="settings-group">
        <label for="edit-ad-bottom">Ad Bottom Slot</label>
        <textarea id="edit-ad-bottom" class="pane-textarea mono" style="min-height: 80px; font-size: 0.75rem; font-family: var(--font-mono); width: 100%;" placeholder="Paste ad code here"></textarea>
      </div>
      <div class="settings-group">
        <label for="edit-ad-sidebar">Ad Sidebar Slot</label>
        <textarea id="edit-ad-sidebar" class="pane-textarea mono" style="min-height: 80px; font-size: 0.75rem; font-family: var(--font-mono); width: 100%;" placeholder="Paste ad code here"></textarea>
      </div>
    </div>

    <!-- Tool FAQs -->
    <h4 style="margin: 0.5rem 0 0 0; border-bottom: 1px solid var(--card-border); padding-bottom: 0.5rem; font-family: var(--font-heading);">Edit Tool FAQs</h4>
    <div class="settings-group">
      <div id="modal-faqs-list" style="display: flex; flex-direction: column; gap: 0.75rem; background: rgba(0,0,0,0.18); border: 1px solid var(--card-border); padding: 1rem; border-radius: 8px; max-height: 220px; overflow-y: auto;">
        <!-- Dynamic FAQs loaded here -->
      </div>
      <button id="modal-add-faq-btn" class="btn btn-secondary" style="margin-top: 0.75rem; padding: 0.35rem 0.75rem; font-size: 0.8rem; align-self: flex-start;">+ Add FAQ Item</button>
    </div>

    <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
      <button class="btn btn-secondary" id="modal-cancel-btn">Cancel</button>
      <button class="btn btn-primary" id="modal-save-btn">Save Changes</button>
    </div>
  </div>
</div>

<div class="toast-container" id="toast-container"></div>

<!-- Admin panel interactions AJAX scripts -->
<script>
  // Serialize all tools data to allow modal to read values instantly
  window.toolsData = <%- JSON.stringify(tools) %>;
  window.faqsData = <%- JSON.stringify(faqs) %>;

  // Toast Helper
  function showToast(message, type = 'info') {
    const container = document.getElementById('toast-container');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    let icon = '';
    if (type === 'success') {
      icon = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
    } else if (type === 'danger') {
      icon = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
    } else {
      icon = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
    }
    toast.innerHTML = `${icon}<span>${message}</span>`;
    container.appendChild(toast);
    setTimeout(() => {
      toast.classList.add('toast-fadeOut');
      toast.addEventListener('animationend', () => toast.remove());
    }, 3000);
  }

  // Edit Tool Modal logic
  const editModal = document.getElementById('tool-edit-modal');
  const modalToolKey = document.getElementById('modal-tool-key');
  const modalToolName = document.getElementById('modal-tool-name');
  const editName = document.getElementById('edit-name');
  const editSeoTitle = document.getElementById('edit-seo-title');
  const editSeoDesc = document.getElementById('edit-seo-desc');
  const editDescTop = document.getElementById('edit-desc-top');
  const editDescBottom = document.getElementById('edit-desc-bottom');
  const editAdTop = document.getElementById('edit-ad-top');
  const editAdBottom = document.getElementById('edit-ad-bottom');
  const editAdSidebar = document.getElementById('edit-ad-sidebar');
  const editStatus = document.getElementById('edit-status');
  const editImagePath = document.getElementById('edit-image-path');
  const editBulletPoints = document.getElementById('edit-bullet-points');
  const modalFaqsList = document.getElementById('modal-faqs-list');

  // FAQ Row Generator
  function addFaqRowToModal(faqId = '', question = '', answer = '') {
    const row = document.createElement('div');
    row.className = 'faq-editor-row';
    row.dataset.faqId = faqId;
    row.style.cssText = 'border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.75rem; display: flex; flex-direction: column; gap: 0.35rem; position: relative; margin-bottom: 0.5rem;';
    
    row.innerHTML = `
      <input type="text" class="faq-q-input styled-input" style="font-size: 0.85rem; padding: 0.4rem 0.6rem; width: calc(100% - 30px);" value="${question.replace(/"/g, '&quot;')}" placeholder="FAQ Question">
      <textarea class="faq-a-input pane-textarea" style="font-size: 0.82rem; min-height: 45px; width: 100%; margin: 0; padding: 0.4rem 0.6rem;" placeholder="FAQ Answer">${answer}</textarea>
      <button class="modal-faq-del-btn" style="position: absolute; top: 0.4rem; right: 0; background: none; border: none; color: var(--danger); cursor: pointer; font-size: 1.25rem; font-weight: bold;">&times;</button>
    `;
    
    // Bind delete button
    row.querySelector('.modal-faq-del-btn').addEventListener('click', () => {
      row.remove();
    });
    
    modalFaqsList.appendChild(row);
  }

  // Bind Add FAQ button
  document.getElementById('modal-add-faq-btn').addEventListener('click', (e) => {
    e.preventDefault();
    addFaqRowToModal();
  });

  document.querySelectorAll('.btn-edit-tool').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const toolKey = e.target.getAttribute('data-tool-key');
      const tool = window.toolsData.find(t => t.tool_key === toolKey);
      if (!tool) return;

      modalToolKey.value = tool.tool_key;
      modalToolName.textContent = `Edit Tool: ${tool.name}`;
      editName.value = tool.name;
      editSeoTitle.value = tool.seo_title || '';
      editSeoDesc.value = tool.seo_meta_desc || tool.intro_paragraph || tool.page_description || '';
      editDescTop.value = tool.description_top || '';
      editDescBottom.value = tool.description_bottom || '';
      editAdTop.value = tool.ad_top || '';
      editAdBottom.value = tool.ad_bottom || '';
      editAdSidebar.value = tool.ad_sidebar || '';
      editStatus.value = tool.status || 'active';
      editImagePath.value = tool.image_path || '';
      editBulletPoints.value = tool.bullet_points || '';

      // Populate FAQs for this tool
      modalFaqsList.innerHTML = '';
      const toolFaqs = window.faqsData.filter(f => f.tool_id === tool.id);
      toolFaqs.forEach(faq => {
        addFaqRowToModal(faq.id, faq.question, faq.answer);
      });

      editModal.style.setProperty('display', 'flex', 'important');
    });
  });

  const closeModal = () => {
    editModal.style.setProperty('display', 'none', 'important');
  };

  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('modal-cancel-btn').addEventListener('click', closeModal);

  document.getElementById('modal-save-btn').addEventListener('click', async () => {
    const toolKey = modalToolKey.value;
    
    // Collect FAQs
    const faqs = [];
    document.querySelectorAll('.faq-editor-row').forEach(row => {
      const q = row.querySelector('.faq-q-input').value;
      const a = row.querySelector('.faq-a-input').value;
      if (q.trim() !== '' && a.trim() !== '') {
        faqs.push({
          id: row.dataset.faqId || null,
          question: q,
          answer: a
        });
      }
    });

    const payload = {
      tool_key: toolKey,
      name: editName.value,
      seo_title: editSeoTitle.value,
      seo_meta_desc: editSeoDesc.value,
      description_top: editDescTop.value,
      description_bottom: editDescBottom.value,
      ad_top: editAdTop.value,
      ad_bottom: editAdBottom.value,
      ad_sidebar: editAdSidebar.value,
      status: editStatus.value,
      image_path: editImagePath.value,
      bullet_points: editBulletPoints.value,
      faqs: faqs
    };

    try {
      const res = await fetch('/api/admin/tools/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const data = await res.json();
      if (data.success) {
        showToast('Changes saved to database!', 'success');
        setTimeout(() => window.location.reload(), 800);
      } else {
        showToast('Save failed: ' + data.error, 'danger');
      }
    } catch (err) {
      showToast('Failed to save settings: ' + err.message, 'danger');
    }
  });

  // 2. Hook up Tool Active State Toggle
  document.querySelectorAll('.tool-toggle-checkbox').forEach(toggle => {
    toggle.addEventListener('change', async (e) => {
      const toolKey = e.target.getAttribute('data-tool');
      const enabled = e.target.checked;
      
      try {
        const res = await fetch('/api/admin/tools/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tool_key: toolKey, enabled: enabled })
        });
        const data = await res.json();
        if (data.success) {
          showToast(`Engine state updated successfully!`, 'success');
          
          // Dynamically adjust stats active label on header
          const activeText = document.getElementById('stats-active-count');
          if (activeText) {
            const parts = activeText.textContent.split(' / ');
            let count = parseInt(parts[0]);
            count = enabled ? count + 1 : count - 1;
            activeText.textContent = `${count} / ${parts[1]}`;
          }
        } else {
          showToast('Failed to update state: ' + data.error, 'danger');
          e.target.checked = !enabled; // Revert
        }
      } catch (err) {
        showToast('Communication failure', 'danger');
        e.target.checked = !enabled; // Revert
      }
    });
  });

  // 3. Add FAQ AJAX Submit
  const addFaqForm = document.getElementById('add-faq-form');
  if (addFaqForm) {
    addFaqForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = {
        tool_id: document.getElementById('faq-tool-id').value,
        question: document.getElementById('faq-question').value,
        answer: document.getElementById('faq-answer').value
      };
      
      try {
        const res = await fetch('/api/admin/faqs/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        
        if (data.success) {
          showToast('FAQ added to database!', 'success');
          // Reload page to list new item
          setTimeout(() => window.location.reload(), 800);
        } else {
          showToast('Failed to add FAQ: ' + data.error, 'danger');
        }
      } catch (err) {
        showToast('Communication error', 'danger');
      }
    });
  }

  // 4. Delete FAQ AJAX Click
  document.querySelectorAll('.btn-delete-faq').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const faqId = e.target.getAttribute('data-faq-id');
      if (!confirm('Are you sure you want to delete this FAQ item?')) return;
      
      try {
        const res = await fetch('/api/admin/faqs/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ faq_id: faqId })
        });
        const data = await res.json();
        
        if (data.success) {
          showToast('FAQ removed!', 'success');
          // Remove from UI list
          document.querySelector(`.faq-item-card[data-faq-id="${faqId}"]`).remove();
        } else {
          showToast('Failed to delete FAQ: ' + data.error, 'danger');
        }
      } catch (err) {
        showToast('Communication error', 'danger');
      }
    });
  });

  // 5. Wipe stats logs
  const btnWipeStats = document.getElementById('btn-wipe-stats');
  if (btnWipeStats) {
    btnWipeStats.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to reset all tool conversions to zero?')) return;
      try {
        const res = await fetch('/api/admin/stats/wipe', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          showToast('Database conversion counters reset to zero!', 'success');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('Wipe failed: ' + data.error, 'danger');
        }
      } catch (err) {
        showToast('Wipe error', 'danger');
      }
    });
  }

  // 6. Ads Form settings submit handler
  const adsForm = document.getElementById('ads-config-form');
  if (adsForm) {
    adsForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = {
        ad_header: document.getElementById('ad-header').value,
        ad_sidebar: document.getElementById('ad-sidebar').value,
        ad_footer: document.getElementById('ad-footer').value
      };
      
      try {
        const res = await fetch('/api/admin/settings/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (data.success) {
          showToast('Ads configuration saved successfully!', 'success');
        } else {
          showToast('Failed to save ads configuration: ' + data.error, 'danger');
        }
      } catch (err) {
        showToast('Error saving configuration: ' + err.message, 'danger');
      }
    });
  }
</script>

