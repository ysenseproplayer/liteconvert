<%- include('../partials/header', { activePage: 'admin' }) %>
<%- include('../partials/sidebar', { activePage: 'admin' }) %>

<main class="workspace" style="margin-left: 280px; width: calc(100% - 280px);">
  <header class="workspace-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--card-border); padding-bottom: 1.5rem; margin-bottom: 2rem;">
    <div class="title-area">
      <h2 id="tool-title">CMS Admin Control Panel</h2>
      <p id="tool-description" class="subtitle">Logged in as: <strong><%= username %></strong></p>
    </div>
    <div>
      <a href="/admin/logout" class="btn btn-secondary">Logout</a>
    </div>
  </header>

  <div class="workspace-content">
    
    <!-- STATS MODULES -->
    <div class="dashboard-grid">
      <div class="stat-card">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
        </div>
        <div class="stat-info">
          <h4>Total Conversions Log</h4>
          <div class="stat-number" id="stats-total-conversions"><%= totalConversions %></div>
        </div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon-wrapper success">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="stat-info">
          <h4>Active Tools</h4>
          <div class="stat-number" id="stats-active-count"><%= activeCount %> / <%= tools.length %></div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon-wrapper warning">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" /></svg>
        </div>
        <div class="stat-info">
          <h4>Database State</h4>
          <div class="stat-number" style="color: var(--success);">Connected</div>
        </div>
      </div>
    </div>

    <!-- MODULE SETTINGS CMS TABLE -->
    <h3 class="settings-section-title">Module Settings CMS</h3>
    <div class="card admin-card" style="margin-bottom: 2.5rem;">
      <table class="admin-table">
        <thead>
          <tr>
            <th style="width: 20%;">Tool name</th>
            <th style="width: 25%;">SEO Title</th>
            <th style="width: 35%;">Page Content (SEO)</th>
            <th style="width: 10%; text-align: center;">Status</th>
            <th style="width: 10%; text-align: center;">Conversions</th>
          </tr>
        </thead>
        <tbody>
          <% tools.forEach(t => { %>
            <tr data-tool-key="<%= t.tool_key %>">
              <td>
                <input type="text" class="inline-edit-input bold txt-name" value="<%= t.name %>" style="width: 100%;"><br>
                <span style="font-size: 0.7rem; color: var(--text-muted); font-family: var(--font-mono); padding-left: 0.6rem;"><%= t.tool_key %></span>
              </td>
              <td>
                <input type="text" class="inline-edit-input txt-seo-title" value="<%= t.seo_title %>" style="width: 100%; font-size: 0.85rem;"><br>
                <textarea class="inline-edit-input txt-seo-desc" style="width: 100%; font-size: 0.75rem; min-height: 50px; margin-top: 0.25rem;" placeholder="Meta Desc"><%= t.seo_meta_desc %></textarea>
              </td>
              <td>
                <textarea class="inline-edit-input txt-desc" style="width: 100%; font-size: 0.85rem; min-height: 80px; line-height: 1.5;"><%= t.page_description %></textarea>
              </td>
              <td style="text-align: center; vertical-align: middle;">
                <label class="switch">
                  <input type="checkbox" class="tool-toggle-checkbox" data-tool="<%= t.tool_key %>" <%= t.enabled ? 'checked' : '' %>>
                  <span class="slider-toggle"></span>
                </label>
              </td>
              <td style="text-align: center; vertical-align: middle; font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-secondary);">
                <%= t.use_count %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- FAQ CMS SECTION -->
    <h3 class="settings-section-title">FAQ Manager (SEO booster)</h3>
    <div class="grid-layout" style="margin-bottom: 2.5rem;">
      <div class="card" style="max-height: 500px; overflow-y: auto;">
        <h3>Existing FAQs list</h3>
        <div style="display: flex; flex-direction: column; gap: 1rem;" id="faqs-list-container">
          <% faqs.forEach(faq => { %>
            <div class="faq-item-card" data-faq-id="<%= faq.id %>" style="border: 1px solid var(--card-border); border-radius: var(--radius-md); padding: 1rem; background-color: rgba(255,255,255,0.01); display: flex; flex-direction: column; gap: 0.5rem; position: relative;">
              <span style="font-size: 0.7rem; background-color: rgba(99, 102, 241, 0.1); color: var(--accent-primary); border-radius: 4px; padding: 0.15rem 0.4rem; font-weight: 600; width: max-content;">
                <%= faq.tool_name %>
              </span>
              <h4 style="font-size: 0.95rem; font-weight: 600;"><%= faq.question %></h4>
              <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5;"><%= faq.answer %></p>
              <button class="text-btn btn-delete-faq" data-faq-id="<%= faq.id %>" style="color: var(--danger); position: absolute; top: 1rem; right: 1rem;">Delete</button>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="card">
        <h3>Add FAQ</h3>
        <form id="add-faq-form">
          <div class="settings-group">
            <label for="faq-tool-id">Select Tool Module</label>
            <select id="faq-tool-id" class="styled-select" required>
              <% tools.forEach(t => { %>
                <option value="<%= t.id %>"><%= t.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="settings-group">
            <label for="faq-question">Question</label>
            <input type="text" id="faq-question" class="styled-input" placeholder="e.g. Is this tool secure?" required>
          </div>
          <div class="settings-group">
            <label for="faq-answer">Answer</label>
            <textarea id="faq-answer" class="pane-textarea" style="min-height: 100px;" placeholder="FAQ answer text..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-full mt-lg">Add FAQ</button>
        </form>
      </div>
    </div>

    <!-- DANGER ZONE -->
    <h3 class="settings-section-title">System Actions</h3>
    <div class="card danger-card">
      <h3>Danger Zone</h3>
      <p class="card-desc">Irreversible administrative parameters and analytics wipes.</p>
      <div class="danger-row">
        <div class="danger-info">
          <h4>Wipe Conversion Counters</h4>
          <p>Resets all tool conversions counts back to zero.</p>
        </div>
        <button class="btn btn-danger" id="btn-wipe-stats">Wipe Stats Logs</button>
      </div>
    </div>

  </div>
</main>

<div class="toast-container" id="toast-container"></div>

<!-- Admin panel interactions AJAX scripts -->
<script>
  // Toast Helper
  function showToast(message, type = 'info') {
    const container = document.getElementById('toast-container');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    let icon = '';
    if (type === 'success') {
      icon = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
    } else if (type === 'danger') {
      icon = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
    } else {
      icon = '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
    }
    toast.innerHTML = `${icon}<span>${message}</span>`;
    container.appendChild(toast);
    setTimeout(() => {
      toast.classList.add('toast-fadeOut');
      toast.addEventListener('animationend', () => toast.remove());
    }, 3000);
  }

  // 1. Hook up Inline CMS Save on Blur / Enter key
  document.querySelectorAll('.admin-table tbody tr').forEach(row => {
    const toolKey = row.getAttribute('data-tool-key');
    const inputs = row.querySelectorAll('.inline-edit-input');
    
    inputs.forEach(input => {
      input.addEventListener('change', async () => {
        const payload = {
          tool_key: toolKey,
          name: row.querySelector('.txt-name').value,
          seo_title: row.querySelector('.txt-seo-title').value,
          seo_meta_desc: row.querySelector('.txt-seo-desc').value,
          desc: row.querySelector('.txt-desc').value
        };
        
        try {
          const res = await fetch('/api/admin/tools/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await res.json();
          if (data.success) {
            showToast('Changes saved to database!', 'success');
          } else {
            showToast('Save failed: ' + data.error, 'danger');
          }
        } catch (err) {
          showToast('Failed to connect to backend API', 'danger');
        }
      });
    });
  });

  // 2. Hook up Tool Active State Toggle
  document.querySelectorAll('.tool-toggle-checkbox').forEach(toggle => {
    toggle.addEventListener('change', async (e) => {
      const toolKey = e.target.getAttribute('data-tool');
      const enabled = e.target.checked;
      
      try {
        const res = await fetch('/api/admin/tools/toggle', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tool_key: toolKey, enabled: enabled })
        });
        const data = await res.json();
        if (data.success) {
          showToast(`Engine state updated successfully!`, 'success');
          
          // Dynamically adjust stats active label on header
          const activeText = document.getElementById('stats-active-count');
          if (activeText) {
            const parts = activeText.textContent.split(' / ');
            let count = parseInt(parts[0]);
            count = enabled ? count + 1 : count - 1;
            activeText.textContent = `${count} / ${parts[1]}`;
          }
        } else {
          showToast('Failed to update state: ' + data.error, 'danger');
          e.target.checked = !enabled; // Revert
        }
      } catch (err) {
        showToast('Communication failure', 'danger');
        e.target.checked = !enabled; // Revert
      }
    });
  });

  // 3. Add FAQ AJAX Submit
  const addFaqForm = document.getElementById('add-faq-form');
  if (addFaqForm) {
    addFaqForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = {
        tool_id: document.getElementById('faq-tool-id').value,
        question: document.getElementById('faq-question').value,
        answer: document.getElementById('faq-answer').value
      };
      
      try {
        const res = await fetch('/api/admin/faqs/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        
        if (data.success) {
          showToast('FAQ added to database!', 'success');
          // Reload page to list new item
          setTimeout(() => window.location.reload(), 800);
        } else {
          showToast('Failed to add FAQ: ' + data.error, 'danger');
        }
      } catch (err) {
        showToast('Communication error', 'danger');
      }
    });
  }

  // 4. Delete FAQ AJAX Click
  document.querySelectorAll('.btn-delete-faq').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const faqId = e.target.getAttribute('data-faq-id');
      if (!confirm('Are you sure you want to delete this FAQ item?')) return;
      
      try {
        const res = await fetch('/api/admin/faqs/delete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ faq_id: faqId })
        });
        const data = await res.json();
        
        if (data.success) {
          showToast('FAQ removed!', 'success');
          // Remove from UI list
          document.querySelector(`.faq-item-card[data-faq-id="${faqId}"]`).remove();
        } else {
          showToast('Failed to delete FAQ: ' + data.error, 'danger');
        }
      } catch (err) {
        showToast('Communication error', 'danger');
      }
    });
  });

  // 5. Wipe stats logs
  const btnWipeStats = document.getElementById('btn-wipe-stats');
  if (btnWipeStats) {
    btnWipeStats.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to reset all tool conversions to zero?')) return;
      try {
        const res = await fetch('/api/admin/stats/wipe', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          showToast('Database conversion counters reset to zero!', 'success');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('Wipe failed: ' + data.error, 'danger');
        }
      } catch (err) {
        showToast('Wipe error', 'danger');
      }
    });
  }
</script>

<%- include('../partials/footer') %>
