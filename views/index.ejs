<%- include('partials/header', { activePage: 'dashboard' }) %>
<%- include('partials/sidebar', { activePage: 'dashboard' }) %>

<main class="workspace" style="margin-left: 280px; width: calc(100% - 280px);">
  <header class="workspace-header">
    <div class="title-area">
      <h2 id="tool-title">Dashboard</h2>
      <p id="tool-description" class="subtitle">Access and manage premium high-performance conversion utilities.</p>
    </div>
  </header>

  <div class="workspace-content">
    <!-- HEADER AD UNIT -->
    <% if (typeof globalSettings !== 'undefined' && globalSettings.ad_header) { %>
      <div class="ad-container ad-header" style="margin-bottom: 2rem; text-align: center;">
        <%- globalSettings.ad_header %>
      </div>
    <% } %>

    <!-- Quick stats metrics -->
    <div class="dashboard-grid">
      <div class="stat-card">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
        </div>
        <div class="stat-info">
          <h4>Total Conversions</h4>
          <div class="stat-number"><%= totalConversions %></div>
        </div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon-wrapper success">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="stat-info">
          <h4>Active Modules</h4>
          <div class="stat-number"><%= activeCount %> / <%= tools.length %></div>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon-wrapper warning">
          <svg class="stat-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        </div>
        <div class="stat-info">
          <h4>System Status</h4>
          <div class="stat-number">Online</div>
        </div>
      </div>
    </div>

    <!-- Available Tools showcase -->
    <div class="tools-showcase">
      <h3 class="tools-showcase-title">
        <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
        Available Conversion Engines
      </h3>
      
      <%
        const categories = {};
        tools.forEach(t => {
          if (!categories[t.category]) categories[t.category] = [];
          categories[t.category].push(t);
        });
      %>
      
      <% Object.keys(categories).forEach(cat => { %>
        <div class="category-block" style="margin-top: 3rem; margin-bottom: 2rem;">
          <h4 style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 700; color: var(--accent-primary); text-transform: uppercase; margin-bottom: 1.5rem; letter-spacing: 0.05em; border-bottom: 2px solid rgba(99, 102, 241, 0.2); padding-bottom: 0.5rem; display: inline-block;">
            <%= cat %>
          </h4>
          <div class="tools-grid">
            <% categories[cat].forEach(t => { %>
              <% const isEnabled = t.enabled; %>
              <a href="<%= isEnabled ? '/tool/' + t.tool_key : '#' %>" class="tool-card <%= isEnabled ? '' : 'disabled' %>">
                <div class="tool-card-header">
                  <div class="tool-card-icon">
                    <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                  </div>
                  <% if (!isEnabled) { %>
                    <div class="tool-card-lock">
                      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
                      Locked
                    </div>
                  <% } %>
                </div>
                <h3><%= t.name %></h3>
                <p><%= (t.seo_meta_desc || '').substring(0, 110) %>...</p>
                <div class="tool-card-footer">
                  <span class="tool-badge <%= isEnabled ? 'stats' : 'disabled' %>">
                    <%= isEnabled ? `${t.use_count} conversions` : 'Disabled' %>
                  </span>
                  <% if (isEnabled) { %>
                    <span class="tool-action-link">
                      Open Tool
                      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                    </span>
                  <% } %>
                </div>
              </a>
            <% }); %>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- DYNAMIC FAQ SECTION -->
    <% if (typeof faqs !== 'undefined' && faqs.length > 0) { %>
      <div class="card" style="margin-top: 3rem; margin-bottom: 2.5rem;">
        <h3 style="font-family: var(--font-heading); font-size: 1.35rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;">
          <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Frequently Asked Questions
        </h3>
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <% faqs.forEach((faq, index) => { %>
            <div class="faq-item" style="border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 1.25rem;">
              <h4 style="font-family: var(--font-heading); font-size: 1.05rem; margin-bottom: 0.5rem; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem;">
                <span style="font-size: 0.75rem; background-color: rgba(99, 102, 241, 0.1); color: var(--accent-primary); border-radius: 4px; padding: 0.15rem 0.4rem; font-weight: 600;">
                  <%= faq.tool_name %>
                </span>
                <span><%= faq.question %></span>
              </h4>
              <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6; padding-left: 0.5rem;"><%= faq.answer %></p>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>
    <!-- FOOTER AD UNIT -->
    <% if (typeof globalSettings !== 'undefined' && globalSettings.ad_footer) { %>
      <div class="ad-container ad-footer" style="margin-top: 3rem; text-align: center;">
        <%- globalSettings.ad_footer %>
      </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>
