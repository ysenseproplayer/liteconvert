<%- include('partials/header', { tool: tool }) %>
<%- include('partials/sidebar', { activePage: tool.tool_key }) %>

<main class="workspace" style="margin-left: 280px; width: calc(100% - 280px);">
  <header class="workspace-header">
    <div class="title-area">
      <h2 id="tool-title"><%= tool.name %></h2>
      <p id="tool-description" class="subtitle">Category: <%= tool.category %></p>
    </div>
  </header>

  <div class="workspace-content">
    
    <!-- AD TOP SLOT -->
    <% if (tool.ad_top && tool.ad_top.trim() !== '') { %>
      <div class="ad-slot ad-top" style="margin-bottom: 2rem; text-align: center; max-width: 100%; overflow: hidden;">
        <%- tool.ad_top %>
      </div>
    <% } %>

    <!-- DESCRIPTION TOP PARAGRAPH -->
    <% if (tool.description_top && tool.description_top.trim() !== '') { %>
      <div class="card intro-paragraph-card" style="margin-bottom: 2rem; line-height: 1.7; border-left: 4px solid var(--accent-primary);">
        <p style="color: var(--text-secondary); font-size: 0.95rem; margin: 0;"><%= tool.description_top %></p>
      </div>
    <% } %>
    
    <!-- DYNAMIC TOOL INTERFACE EMBED -->
    <div style="margin-bottom: 2.5rem;">
      <%- include('tools/' + tool.tool_key) %>
    </div>

    <!-- AD BOTTOM SLOT -->
    <% if (tool.ad_bottom && tool.ad_bottom.trim() !== '') { %>
      <div class="ad-slot ad-bottom" style="margin-bottom: 2.5rem; text-align: center; max-width: 100%; overflow: hidden;">
        <%- tool.ad_bottom %>
      </div>
    <% } %>

    <!-- DESCRIPTION BOTTOM PARAGRAPH -->
    <% if (tool.description_bottom && tool.description_bottom.trim() !== '') { %>
      <div class="card about-paragraph-card" style="margin-bottom: 2.5rem; line-height: 1.7;">
        <h3 style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--text-primary); margin-bottom: 1rem;">About <%= tool.name %></h3>
        <p style="color: var(--text-secondary); font-size: 0.95rem; margin: 0;"><%= tool.description_bottom %></p>
      </div>
    <% } %>

    <!-- DYNAMIC FAQ SECTION -->
    <% if (typeof faqs !== 'undefined' && faqs.length > 0) { %>
      <div class="card" style="margin-bottom: 2.5rem;">
        <h3 style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--text-primary); margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem;">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Frequently Asked Questions
        </h3>
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          <% faqs.forEach((faq, index) => { %>
            <div class="faq-item" style="border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding-bottom: 1rem;">
              <h4 style="font-family: var(--font-heading); font-size: 1.05rem; margin-bottom: 0.5rem; color: var(--text-primary); cursor: pointer; display: flex; justify-content: space-between; align-items: center;">
                <span><%= faq.question %></span>
              </h4>
              <p style="color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6;"><%= faq.answer %></p>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

  </div>
</main>

<div class="toast-container" id="toast-container"></div>

<!-- Dynamically load the client side tool runner script -->
<script type="module" src="/src/tools/<%= tool.tool_key %>.js?v=5"></script>

<%- include('partials/footer') %>
